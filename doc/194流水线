/**
 * 解析配置文件内容，支持多行格式
 * 
 * 支持两种格式：
 * 1. 单行格式：KEY=value1,value2,value3
 * 2. 多行格式：
 *    KEY=
 *        value1
 *        value2
 *        # 注释行会被忽略
 *        value3
 * 
 * @param configContent 配置文件内容字符串
 * @return 解析后的配置 Map
 * 
 * Requirements: 9.1, 9.2, 9.3
 */
def parseConfigContent(String configContent) {
    def buildConfigMap = [:]
    def configLines = configContent.split('\n')
    
    def currentKey = null
    def currentValue = new StringBuilder()
    def isMultiLine = false
    
    configLines.each { line ->
        def rawLine = line
        def trimmedLine = line.trim()
        
        // 检查是否是续行（以空格或制表符开头，且当前有活动的多行配置）
        if (isMultiLine && currentKey && (rawLine.startsWith(' ') || rawLine.startsWith('\t'))) {
            // 忽略空行和注释行
            if (trimmedLine && !trimmedLine.startsWith('#')) {
                if (currentValue.length() > 0) {
                    currentValue.append('\n')
                }
                currentValue.append(trimmedLine)
            }
            return // continue to next line
        }
        
        // 如果之前有多行配置，先保存它
        if (isMultiLine && currentKey) {
            buildConfigMap[currentKey] = currentValue.toString()
            echo "配置项: ${currentKey} = ${buildConfigMap[currentKey]}"
            currentKey = null
            currentValue = new StringBuilder()
            isMultiLine = false
        }
        
        // 跳过空行和注释行
        if (!trimmedLine || trimmedLine.startsWith('#')) {
            return // continue to next line
        }
        
        // 解析 KEY=VALUE 格式
        if (trimmedLine.contains('=')) {
            def parts = trimmedLine.split('=', 2)
            if (parts.size() == 2) {
                def key = parts[0].trim()
                def value = parts[1].trim().replaceAll(/^['"]|['"]$/, '')
                
                if (value.isEmpty()) {
                    // 值为空，可能是多行格式的开始
                    currentKey = key
                    currentValue = new StringBuilder()
                    isMultiLine = true
                } else {
                    // 单行格式
                    buildConfigMap[key] = value
                    echo "配置项: ${key} = ${value}"
                }
            }
        }
    }
    
    // 处理最后一个多行配置
    if (isMultiLine && currentKey) {
        buildConfigMap[currentKey] = currentValue.toString()
        echo "配置项: ${currentKey} = ${buildConfigMap[currentKey]}"
    }
    
    return buildConfigMap
}

// 从配置中安全获取值
def getConfigValue(configMap, key, defaultValue = '') {
    if (configMap && configMap instanceof Map) {
        return configMap.get(key) ?: defaultValue
    }
    return defaultValue
}

// 设置构建环境
def setupBuildEnvironment() {
    // 加载配置
    def buildConfig = loadBuildConfig()
    
    // 安全获取配置值
    def gradleVersion = getConfigValue(buildConfig, 'GRADLE_VERSION', env.DEFAULT_GRADLE_VERSION)
    def javaVersion = getConfigValue(buildConfig, 'JAVA_VERSION', env.DEFAULT_JAVA_VERSION)
    
    // 设置Gradle路径
    env.GRADLE_SCRIPT = "${env.GRADLE_BASE_DIR}/gradle-${gradleVersion}/bin/gradle"
    
    // 设置Java路径
    env.COMPILE_JAVA_HOME = "${env.JAVA_BASE_DIR}/java-${javaVersion}-openjdk-amd64"
    
    // 如果上述标准路径不存在，尝试其他常见路径模式
    if (!fileExists(env.COMPILE_JAVA_HOME)) {
        def alternativePath = "${env.JAVA_BASE_DIR}/java-1.${javaVersion}.0-openjdk-amd64"
        if (fileExists(alternativePath)) {
            env.COMPILE_JAVA_HOME = alternativePath
            echo "使用备选Java路径: ${env.COMPILE_JAVA_HOME}"
        }
    }
    
    echo "构建环境设置完成:"
    echo "- Gradle: ${env.GRADLE_SCRIPT} (版本: ${gradleVersion})"
    echo "- Java: ${env.COMPILE_JAVA_HOME} (版本: ${javaVersion})"
}

