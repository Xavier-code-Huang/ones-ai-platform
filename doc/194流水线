/**
 * 追加 APK URL 到现有内容
 * 
 * 将新的 APK URL 追加到现有内容末尾，确保不丢失原有链接。
 * 
 * @param existingContent 现有文件内容
 * @param newApkUrl 新的 APK 下载链接
 * @return 更新后的文件内容
 * 
 * Requirements: 7.4
 */
def appendApkUrl(String existingContent, String newApkUrl) {
    if (!newApkUrl || newApkUrl.trim().isEmpty()) {
        return existingContent ?: ''
    }

    def normalizeUrl = { String url ->
        def trimmed = url?.trim()
        if (!trimmed) {
            return ''
        }
        def matcher = trimmed =~ /(.*)_\d+(?:\.\d+)+_[0-9a-fA-F]+(?:_[^\\/]+)?\.apk$/
        if (matcher.matches()) {
            return matcher[0][1]
        }
        if (trimmed.endsWith('.apk')) {
            return trimmed.substring(0, trimmed.length() - 4)
        }
        return trimmed
    }

    if (!existingContent || existingContent.trim().isEmpty()) {
        return existingContent ?: ''
    }

    def newKey = normalizeUrl(newApkUrl)
    def replaced = false
    def lines = existingContent.readLines()
    def updatedLines = lines.collect { line ->
        def trimmed = line?.trim()
        if (!trimmed) {
            return line
        }
        if (normalizeUrl(trimmed) == newKey) {
            if (replaced) {
                return null
            }
            replaced = true
            return newApkUrl
        }
        return line
    }.findAll { it != null }

    if (!replaced) {
        return existingContent
    }

    return updatedLines.join('\n')
}

// ========== SVN 上传辅助函数 ==========

/**
 * 从 APK 文件路径或文件名中提取渠道信息
 * 
 * @param apkFilePath APK 文件完整路径
 * @param apkFileName APK 文件名
 * @return 渠道名称
 */
def extractChannelFromApk(String apkFilePath, String apkFileName) {
    // 尝试从文件名中提取渠道
    // 假设文件名格式为: ProjectName_version_channel.apk 或 ProjectName-channel-version.apk
    
    // 移除 .apk 后缀
    def baseName = apkFileName.replace('.apk', '')
    
    // 尝试匹配常见的命名模式
    // 模式1: ProjectName_version_channel (如 XbhLauncher_1.0.0_xbh)
    def matcher1 = baseName =~ /.*_([^_]+)$/
    if (matcher1.find()) {
        def channel = matcher1.group(1)
        // 排除版本号格式（如 1.0.0）
        if (!channel.matches(/^\d+(\.\d+)*$/)) {
            return channel
        }
    }
    
    // 模式2: ProjectName-channel-version (如 XbhLauncher-xbh-1.0.0)
    def matcher2 = baseName =~ /.*-([a-zA-Z]+)-\d+/
    if (matcher2.find()) {
        return matcher2.group(1)
    }
    
    // 尝试从目录结构中提取渠道
    // 假设目录结构为: out/channel/xxx.apk
    def pathParts = apkFilePath.tokenize('/')
    if (pathParts.size() >= 2) {
        def parentDir = pathParts[-2]
        // 如果父目录不是 out，可能是渠道目录
        if (parentDir != 'out' && !parentDir.matches(/^\d+(\.\d+)*$/)) {
            return parentDir
        }
    }
    
    // 默认返回 'default' 渠道
    return 'default'
}

/**
 * 上传单个文件到 SVN
 * 
 * @param localPath 本地文件路径
 * @param remoteUrl SVN 远程 URL
 * @param fileType 文件类型描述（用于日志）
 * @return boolean 上传是否成功
 */
def uploadFileToSvn(String localPath, String remoteUrl, String fileType) {
    echo "上传 ${fileType}: ${localPath} -> ${remoteUrl}"
    
    try {
        // 检查文件是否已存在
        def fileExists = sh(script: """
            svn ls "${remoteUrl}" --username "\$SVN_USER" --password "\$SVN_PASS" --no-auth-cache --non-interactive >/dev/null 2>&1 && echo "exists" || echo "not_exists"
        """, returnStdout: true).trim()
        
        if (fileExists == "exists") {
            if (env.FORCE_UPLOAD == 'true') {
                echo "${fileType} 文件已存在，强制覆盖..."
                // 先删除旧文件
                sh(script: """
                    svn delete "${remoteUrl}" \\
                        -m "强制覆盖: 删除旧版本 ${fileType} - Build ${BUILD_NUMBER}" \\
                        --username "\$SVN_USER" \\
                        --password "\$SVN_PASS" \\
                        --no-auth-cache \\
                        --non-interactive
                """)
            } else {
                echo "${fileType} 文件已存在，跳过上传: ${remoteUrl}"
                return true // 视为成功（跳过）
            }
        }
        
        // 上传文件
        def uploadResult = sh(script: """
            svn import --force "${localPath}" "${remoteUrl}" \\
                -m "自动构建上传: ${env.PROJECT_NAME} - ${fileType} - ${env.ACTUAL_BRANCH} - Build ${BUILD_NUMBER}" \\
                --username "\$SVN_USER" \\
                --password "\$SVN_PASS" \\
                --no-auth-cache \\
                --non-interactive
        """, returnStatus: true)
        
        if (uploadResult == 0) {
            echo "${fileType} 上传成功: ${remoteUrl}"
            return true
        } else {
            echo "${fileType} 上传失败: ${remoteUrl}"
            return false
        }
    } catch (Exception e) {
        echo "${fileType} 上传异常: ${e.getMessage()}"
        return false
    }
}

// ========== apkinfo.json 解析函数 ==========

/**
 * 解析 apkinfo.json 文件
 * 
 * @param jsonFilePath apkinfo.json 文件路径
 * @return 包含 flavor、version、buildTime、apkFileName、repositoryList 的 Map
 *         如果解析失败返回 null
 * 
 * Requirements: 4.2, 4.4
 */
def parseApkInfoJson(String jsonFilePath) {
    if (!jsonFilePath || !fileExists(jsonFilePath)) {
        echo "apkinfo.json 文件不存在: ${jsonFilePath}"
        return null
    }
    
    try {
        def jsonContent = readFile(jsonFilePath)
        def lazyMap = new groovy.json.JsonSlurper().parseText(jsonContent)
        
        // 将 LazyMap 转换为普通 HashMap，避免 Jenkins 序列化问题
        def apkInfo = convertToSerializableMap(lazyMap)
        
        // 验证必需字段（repositoryList 可选）
        def requiredFields = ['flavor', 'version', 'buildTime', 'apkFileName']
        def missingFields = requiredFields.findAll { !apkInfo.containsKey(it) }
        
        if (missingFields) {
            echo "apkinfo.json 缺少必需字段: ${missingFields.join(', ')}"
            return null
        }
        
        echo "成功解析 apkinfo.json:"
        echo "  - flavor: ${apkInfo.flavor}"
        echo "  - version: ${apkInfo.version}"
        echo "  - buildTime: ${apkInfo.buildTime}"
        echo "  - apkFileName: ${apkInfo.apkFileName}"
        echo "  - repositoryList: ${apkInfo.repositoryList?.size() ?: 0} 个仓库"
        
        return apkInfo
    } catch (Exception e) {
        echo "解析 apkinfo.json 失败: ${e.getMessage()}"
        return null
    }
}

/**
 * 将 LazyMap 转换为可序列化的 HashMap
 * 解决 Jenkins Pipeline 中 groovy.json.internal.LazyMap 不可序列化的问题
 * 
 * @param obj 要转换的对象
 * @return 可序列化的对象
 */
def convertToSerializableMap(obj) {
    if (obj instanceof Map) {
        def result = [:]
        obj.each { key, value ->
            result[key] = convertToSerializableMap(value)
        }
        return result
    } else if (obj instanceof List) {
        return obj.collect { convertToSerializableMap(it) }
    } else {
        return obj
    }
}

/**
 * 从 apkInfo 中获取 repositoryList
 * 
 * @param apkInfo 解析后的 apkInfo Map
 * @return CustomerRepository 列表，每个元素包含 server、repositoryPath、branch 字段
 *         如果 apkInfo 为空或 repositoryList 不存在，返回空列表
 * 
 * Requirements: 4.4
 */
def getRepositoryListFromApkInfo(Map apkInfo) {
    if (!apkInfo || !apkInfo.repositoryList) {
        return []
    }
    
    def repositories = []
    
    apkInfo.repositoryList.each { repo ->
        // 验证每个仓库对象包含必需字段
        if (repo.server && repo.repositoryPath && repo.branch) {
            repositories.add([
                server: repo.server?.toString(),
                repositoryPath: repo.repositoryPath?.toString(),
                branch: repo.branch?.toString()
            ])
        } else {
            echo "警告: repositoryList 中的仓库对象缺少必需字段: ${repo}"
        }
    }
    
    return repositories
}

/**
 * 查找 APK 对应的 apkinfo.json 文件
 * 
 * 支持两种命名格式：
 * 1. apkinfo.{APK文件名}.json (旧格式)
 * 2. apkInfo_{APK文件名去掉.apk}.json (新格式)
 * 
 * @param apkFilePath APK 文件路径
 * @param apkFileName APK 文件名
 * @return apkinfo.json 文件路径，如果不存在返回 null
 * 
 * Requirements: 4.1
 */
def findApkInfoJsonFile(String apkFilePath, String apkFileName) {
    // 提取 APK 所在目录
    def apkDir = apkFilePath.substring(0, apkFilePath.lastIndexOf('/'))
    
    // 提取 APK 基础名（去掉 .apk 后缀）
    def apkBaseName = apkFileName.replace('.apk', '')
    
    // 尝试新格式: apkInfo_{APK文件名去掉.apk}.json
    // 例如: apkInfo_XbhKeyguard_xbh5_5.2.309_1315e3027d.json
    def newFormatPath = "${apkDir}/apkInfo_${apkBaseName}.json"
    
    echo "查找 apkinfo.json 文件..."
    echo "  APK 路径: ${apkFilePath}"
    echo "  APK 目录: ${apkDir}"
    echo "  尝试新格式: ${newFormatPath}"
    
    if (fileExists(newFormatPath)) {
        echo "找到 apkinfo.json 文件 (新格式): ${newFormatPath}"
        return newFormatPath
    }
    
    // 尝试旧格式: apkinfo.{APK文件名}.json
    def oldFormatPath = "${apkDir}/apkinfo.${apkFileName}.json"
    echo "  尝试旧格式: ${oldFormatPath}"
    
    if (fileExists(oldFormatPath)) {
        echo "找到 apkinfo.json 文件 (旧格式): ${oldFormatPath}"
        return oldFormatPath
    }
    
    // 尝试在整个 out 目录下搜索匹配的文件
    echo "  在 out 目录下搜索: apkInfo_${apkBaseName}.json"
    def searchResult = sh(
        script: "find out/ -type f -name 'apkInfo_${apkBaseName}.json' 2>/dev/null | head -1",
        returnStdout: true
    ).trim()
    
    if (searchResult) {
        echo "通过搜索找到 apkinfo.json 文件: ${searchResult}"
        return searchResult
    }
    
    // 尝试搜索旧格式
    echo "  在 out 目录下搜索: apkinfo.${apkFileName}.json"
    def searchResult2 = sh(
        script: "find out/ -type f -name 'apkinfo.${apkFileName}.json' 2>/dev/null | head -1",
        returnStdout: true
    ).trim()
    
    if (searchResult2) {
        echo "通过搜索找到 apkinfo.json 文件: ${searchResult2}"
        return searchResult2
    }
    
    echo "未找到 apkinfo.json 文件"
    return null
}

// ========== Gradle构建函数 ==========

def gradleBuild(flavor, buildType) {
    sh """
    # 设置Java环境
    export JAVA_HOME=${env.COMPILE_JAVA_HOME}
    export PATH="${env.COMPILE_JAVA_HOME}/bin:\$PATH"
    rm -rf out/
    JAVA_HOME=${env.COMPILE_JAVA_HOME}
    if [ "${flavor}" == "all" ]; then
        ${env.GRADLE_SCRIPT} clean assembleRelease --stacktrace
    else
        ${env.GRADLE_SCRIPT} clean assemble${flavor}${buildType} --stacktrace
    fi
    """
}
