    stages {
        stage('Initialize Build') {
            steps {
                script {
                    initializeBuildContext()
                    setupProjectInfo()
                    
                    // 调试模式处理
                    if (params.PARAM_DEBUG_MODE == 'timer') {
                        env.isUserIdCause = 'false'
                        env.isTimerTriggerCause = 'true'
                        env.isGerritTriggerCause = 'false'
                        echo '强制设置为定时触发模式'
                    } else if (params.PARAM_DEBUG_MODE == 'gerrit') {
                        env.isUserIdCause = 'false'
                        env.isTimerTriggerCause = 'false'
                        env.isGerritTriggerCause = 'true'
                        echo '强制设置为Gerrit触发模式'
                    }
                    
                    // 打印触发类型信息
                    echo "触发类型检查:"
                    echo "isUserIdCause = ${env.isUserIdCause}"
                    echo "isTimerTriggerCause = ${env.isTimerTriggerCause}"
                    echo "isGerritTriggerCause = ${env.isGerritTriggerCause}"
                }
            }
        }
        
        stage('Checkout Source Code') {
            steps {
                script {
                    checkout scmGit(
                        branches: [[name: "*/${env.ACTUAL_BRANCH}"]], 
                        extensions: [], 
                        userRemoteConfigs: [[url: env.ACTUAL_CODE_REPO]]
                    )
                }
            }
        }
        stage('Checkout Patchset') {
            when {
                allOf {
                    environment name: 'isGerritTriggerCause', value: 'true'
                    expression { env.GERRIT_REFSPEC != null && env.GERRIT_REFSPEC != '' }
                }
            }
            steps {
                sh "git fetch origin ${GERRIT_REFSPEC} && git reset --hard FETCH_HEAD"
            }
        }
        stage('Load Build Configuration') {
            steps {
                script {
                    try {
                        loadBuildConfig()
                        setupBuildEnvironment()
                        validateBuildEnvironment()
                        printBuildEnvironment()
                    } catch (Exception e) {
                        // 发送配置失败通知
                        sendConfigFailureNotification(e.getMessage())
                        error("配置加载失败: ${e.getMessage()}")
                    }
                }
            }
        }
        
        stage('Check Compile Flag') {
            steps {
                script {
                    checkCompileFlag()
                }
            }
        }
        
    //   stage('Scan Source Code') {
    //          steps {
    //              script {
    //                  def scanSources = "."
                     
    //                  // 根据扫描模式决定扫描范围
    //                  if (params.SCAN_MODE == 'gerrit_changes_only' && env.isGerritTriggerCause == 'true') {
