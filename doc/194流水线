// 加载构建配置
def loadBuildConfig() {
    def configFile = '.auto_build_config'
    
    // 确保 BUILD_CONFIG 是一个 Map
    if (env.BUILD_CONFIG == null) {
        env.BUILD_CONFIG = "{}" // 初始化为空的 JSON 字符串
    }
    
    // 解析为 Map 对象
    def buildConfigMap = [:]
    
    if (fileExists(configFile)) {
        echo "找到项目构建配置文件: ${configFile}"
        
        try {
            def configContent = readFile(configFile)
            buildConfigMap = parseConfigContent(configContent)
            
            echo "成功加载 ${buildConfigMap.size()} 个配置项"
            
        } catch (Exception e) {
            echo "读取配置文件失败: ${e.getMessage()}"
            throw new Exception("配置文件 .auto_build_config 存在但解析失败: ${e.getMessage()}")
        }
    } else {
        echo "未找到项目构建配置文件: ${configFile}"
        throw new Exception("配置文件 .auto_build_config 不存在，请检查项目配置。")
    }
    
    // 应用默认值：确保新配置参数有默认值以保持向后兼容
    def defaults = getDefaultBuildConfig()
    
    // GERRIT_TRIGGER_ENABLED: 默认 true
    if (!buildConfigMap.containsKey('GERRIT_TRIGGER_ENABLED')) {
        buildConfigMap['GERRIT_TRIGGER_ENABLED'] = defaults['GERRIT_TRIGGER_ENABLED']
        echo "使用默认值: GERRIT_TRIGGER_ENABLED = ${buildConfigMap['GERRIT_TRIGGER_ENABLED']}"
    }
    
    // TIMER_TRIGGER_ENABLED: 默认 true
    if (!buildConfigMap.containsKey('TIMER_TRIGGER_ENABLED')) {
        buildConfigMap['TIMER_TRIGGER_ENABLED'] = defaults['TIMER_TRIGGER_ENABLED']
        echo "使用默认值: TIMER_TRIGGER_ENABLED = ${buildConfigMap['TIMER_TRIGGER_ENABLED']}"
    }
    
    // CUSTOMER_REPOSITORIES: 默认空字符串
    if (!buildConfigMap.containsKey('CUSTOMER_REPOSITORIES')) {
        buildConfigMap['CUSTOMER_REPOSITORIES'] = defaults['CUSTOMER_REPOSITORIES']
        echo "使用默认值: CUSTOMER_REPOSITORIES = ${buildConfigMap['CUSTOMER_REPOSITORIES']}"
    }
    
    // 将配置存储为环境变量（序列化为JSON字符串）
    env.BUILD_CONFIG_JSON = groovy.json.JsonOutput.toJson(buildConfigMap)
    return buildConfigMap
}

