    //                          script: '''git diff --name-only HEAD~1 HEAD 2>/dev/null | grep -E '\\.(java|kt|xml)$' | tr '\\n' ',' | sed 's/,$//' ''',
    //                          returnStdout: true
    //                      ).trim()
                         
    //                      if (changedFiles) {
    //                          scanSources = changedFiles
