        stage('Compile Firmware') {
            when {
                expression { env.SHOULD_COMPILE == 'true' }
            }
            steps {
                script {
                    def flavor = env.isGerritTriggerCause == 'true' ? 'all' : params.PARAM_PLATFORM
                    def buildType = params.IS_NOT_DEBUG == 'Debug' ? 'Debug' : 'Release'
                    
                    echo "开始编译..."
                    echo "项目: ${env.PROJECT_NAME}"
                    echo "分支: ${env.ACTUAL_BRANCH}"
                    echo "平台: ${flavor}"
                    echo "类型: ${buildType}"
                    echo "Gradle: ${env.GRADLE_SCRIPT}"
                    echo "Java: ${env.COMPILE_JAVA_HOME}"
                    
                    // 执行Gradle构建
                    gradleBuild(flavor, buildType)
                    
                    // 调试：显示当前工作目录和构建产物
                    echo "=== 构建产物列表 ==="
                    sh "echo '当前工作目录:' && pwd"
                    sh "find out/ -type f 2>/dev/null | sort || echo '未找到 out 目录'"
                    echo "===================="
                    
                    // 记录生成的APK和mapping文件
                    env.APK_FILES = sh(script: """
                        find out/ -type f -name "*.apk" -exec basename {} \\;""", 
                        returnStdout: true
                    ).trim()
                    
                    env.MAPPING_FILES = sh(script: """
                        find out/ -type f -name "mapping_*" -exec basename {} \\;""", 
                        returnStdout: true
                    ).trim()
                    
                    // 查找 apkinfo.json 文件
                    def apkInfoFiles = sh(script: """
                        find out/ -type f \\( -name "apkInfo_*.json" -o -name "apkinfo.*.json" \\) 2>/dev/null || echo ""
                    """, returnStdout: true).trim()
                    
                    if (apkInfoFiles) {
                        echo "找到 apkinfo.json 文件: ${apkInfoFiles}"
                    } else {
                        echo "警告: 未找到 apkinfo.json 文件，Customer 仓库更新功能将无法使用"
                        echo "请确保 Android 项目的 Gradle 构建脚本配置了生成 apkinfo.json 文件"
                    }
                    
                    if (!env.APK_FILES) {
                        error "未找到APK文件，构建失败。"
                    }
                    
                    echo "编译完成，生成APK文件: ${env.APK_FILES}"
                    if (env.MAPPING_FILES) {
                        echo "生成mapping文件: ${env.MAPPING_FILES}"
                    }
                }
            }
        }
        
        stage('Upload to SVN') {
            when {
                expression { 
                    // 只有手动触发且编译成功且 UPLOAD_TO_SVN 为 true 时才上传
                    // Requirements 3.3: WHEN UPLOAD_TO_SVN 设置为 false THEN THE Pipeline SHALL 完成编译但跳过 SVN 上传阶段
                    // 3.5日改成只需要编译成功就进入上传阶段
                    env.SHOULD_COMPILE == 'true' && params.UPLOAD_TO_SVN
                }
            }
            steps {
                script {
                    def flavor = env.isGerritTriggerCause == 'true' ? 'all' : params.PARAM_PLATFORM
                    
                    // 获取 Customer 仓库配置
                    def buildConfig = [:]
                    try {
                        if (env.BUILD_CONFIG_JSON) {
                            def lazyMap = new groovy.json.JsonSlurper().parseText(env.BUILD_CONFIG_JSON)
                            buildConfig = convertToSerializableMap(lazyMap)
                        }
                    } catch (Exception e) {
                        echo "解析构建配置失败: ${e.getMessage()}"
                    }
                    def customerReposConfig = getConfigValue(buildConfig, 'CUSTOMER_REPOSITORIES', '')
                    def customerRepositories = parseCustomerRepositories(customerReposConfig)
                    
                    // 存储上传的 APK 信息，用于后续更新 apk_urls.txt
                    env.UPLOADED_APKS_JSON = '[]'
                    def uploadedApks = []
                    
                    echo "开始上传到 SVN..."
                    echo "项目: ${env.PROJECT_NAME}"
                    echo "分支: ${env.ACTUAL_BRANCH}"
                    echo "平台/渠道: ${flavor}"
                    echo "Customer 仓库数量: ${customerRepositories.size()}"
                    
                    withCredentials([usernamePassword(
                        credentialsId: 'svn-cred', 
                        usernameVariable: 'SVN_USER',
                        passwordVariable: 'SVN_PASS'
                    )]) {
                        // 查找所有 APK 文件及其对应的渠道目录
                        def apkFiles = sh(script: "find out/ -type f -name '*.apk' 2>/dev/null || true", returnStdout: true).trim()
                        
                        if (!apkFiles) {
                            echo "未找到 APK 文件"
                            env.UPLOAD_SUCCESS = 'false'
                            env.UPLOAD_RESULT_MESSAGE = "未找到 APK 文件"
                            return
                        }
                        
                        def uploadSuccessCount = 0
                        def skipCount = 0
                        def failCount = 0
                        
                        apkFiles.split('\n').each { apkFilePath ->
                            apkFilePath = apkFilePath.trim()
                            if (!apkFilePath) return
                            
                            def apkFileName = apkFilePath.tokenize('/').last()
                            
                            // 优先从 apkInfo.json 中读取 flavor 作为渠道
                            // apkInfo.json 文件格式: apkInfo_{APK文件名去掉.apk}.json
                            def apkInfoJsonPath = findApkInfoJsonFile(apkFilePath, apkFileName)
                            def channel = null
                            def apkInfoData = null
                            
                            if (apkInfoJsonPath) {
                                echo "找到 apkInfo.json: ${apkInfoJsonPath}"
                                apkInfoData = parseApkInfoJson(apkInfoJsonPath)
                                if (apkInfoData && apkInfoData.flavor) {
                                    channel = apkInfoData.flavor
                                    echo "从 apkInfo.json 读取 flavor: ${channel}"
                                }
                            }
                            
                            // 如果无法从 apkInfo.json 获取 flavor，则回退到从文件名提取
                            if (!channel) {
                                channel = extractChannelFromApk(apkFilePath, apkFileName)
                                echo "从文件名提取渠道: ${channel}"
                            }
                            
                            echo "=============================="
                            echo "处理 APK: ${apkFileName}"
                            echo "渠道: ${channel}"
                            
                            // Requirements 6.2: 按 xbh3/仓库名/分支/渠道/ 结构组织文件
                            def svnChannelPath = generateSvnPath(env.PROJECT_NAME, env.ACTUAL_BRANCH, channel)
                            def svnChannelUrl = "${env.SVN_BASE_URL}/${env.PROJECT_NAME}/${env.ACTUAL_BRANCH}/${channel}"
                            
                            echo "SVN 渠道目录: ${svnChannelUrl}"
                            
                            // 确保 SVN 渠道目录存在
                            def mkdirResult = sh(script: """
                                if ! svn ls "${svnChannelUrl}" --username "\$SVN_USER" --password "\$SVN_PASS" --no-auth-cache --non-interactive >/dev/null 2>&1; then
                                    echo "创建 SVN 目录: ${svnChannelUrl}"
                                    svn mkdir --parents "${svnChannelUrl}" -m "创建渠道目录: ${env.PROJECT_NAME}/${env.ACTUAL_BRANCH}/${channel}" --username "\$SVN_USER" --password "\$SVN_PASS" --no-auth-cache --non-interactive
                                fi
                            """, returnStatus: true)
                            
                            // 上传 APK 文件
                            def apkRemoteUrl = "${svnChannelUrl}/${apkFileName}"
                            def uploadSuccess = uploadFileToSvn(apkFilePath, apkRemoteUrl, "APK")
                            
                            if (uploadSuccess) {
                                uploadSuccessCount++
                                
                                // 生成 APK 下载链接
                                def downloadUrl = generateApkDownloadUrl(env.PROJECT_NAME, env.ACTUAL_BRANCH, channel, apkFileName)
                                
                                // 记录上传的 APK 信息
                                uploadedApks.add([
                                    projectName: env.PROJECT_NAME,
                                    branch: env.ACTUAL_BRANCH,
                                    channel: channel,
                                    apkFileName: apkFileName,
                                    downloadUrl: downloadUrl
                                ])
                                
                                // 生成并上传 apk_urls.txt 到 SVN 根目录（xbh3/apk_urls.txt）
                                // 控制方式与之前相同（UPDATE_CUSTOMER_REPO 参数控制）
                                if (params.UPDATE_CUSTOMER_REPO) {
                                    echo "生成 apk_urls.txt 文件..."
                                    def apkUrlTxtLocalPath = "${env.WORKSPACE}/temp_apk_urls_${channel}_${apkFileName.replace('.apk', '')}.txt"
                                    
                                    // apk_urls.txt 放在 SVN 根目录下（xbh3/apk_urls.txt）
                                    def apkUrlTxtRemoteUrl = "${env.SVN_BASE_URL}/apk_urls.txt"
                                    def existingContent = ''
                                    try {
                                        def checkResult = sh(
                                            script: """
                                                svn ls "${apkUrlTxtRemoteUrl}" \\
                                                    --username "\$SVN_USER" \\
                                                    --password "\$SVN_PASS" \\
                                                    --no-auth-cache \\
                                                    --non-interactive 2>/dev/null
                                            """,
                                            returnStatus: true
                                        )
                                        if (checkResult == 0) {
                                            existingContent = sh(
                                                script: """
                                                    svn cat "${apkUrlTxtRemoteUrl}" \\
                                                        --username "\$SVN_USER" \\
                                                        --password "\$SVN_PASS" \\
                                                        --no-auth-cache \\
                                                        --non-interactive 2>/dev/null || echo ""
                                                """,
                                                returnStdout: true
                                            ).trim()
                                        }
                                    } catch (Exception e) {
                                        echo "读取现有 apk_urls.txt 时出错: ${e.getMessage()}"
                                    }
                                    
                                    // 追加新的 APK URL
                                    def updatedContent = appendApkUrl(existingContent, downloadUrl)
                                    writeFile file: apkUrlTxtLocalPath, text: updatedContent
                                    
                                    // 上传 apk_urls.txt 到 SVN，强制覆盖已有文件
                                    def previousForceUpload = env.FORCE_UPLOAD
                                    env.FORCE_UPLOAD = 'true'
                                    uploadFileToSvn(apkUrlTxtLocalPath, apkUrlTxtRemoteUrl, "apk_urls.txt")
                                    if (previousForceUpload != null) {
                                        env.FORCE_UPLOAD = previousForceUpload
                                    } else {
                                        env.FORCE_UPLOAD = 'false'
                                    }
                                    
                                    // 清理临时文件
                                    sh "rm -f '${apkUrlTxtLocalPath}'"
                                }
                                
                                // Requirements 4.3: 上传编译产物中的 apkinfo.json 文件（如存在）
                                // apkInfoJsonPath 已在前面获取 flavor 时查找过
                                if (apkInfoJsonPath) {
                                    def apkInfoJsonFileName = apkInfoJsonPath.tokenize('/').last()
                                    def apkInfoJsonRemoteUrl = "${svnChannelUrl}/${apkInfoJsonFileName}"
                                    uploadFileToSvn(apkInfoJsonPath, apkInfoJsonRemoteUrl, "apkinfo.json")
                                    
                                    // 存储 apkinfo.json 路径供后续阶段使用
                                    uploadedApks[-1].apkInfoJsonPath = apkInfoJsonPath
                                }
                                
                                // Requirements 4.1, 4.3, 3.4: 生成并上传 repository_list.info 文件
                                if (params.UPDATE_CUSTOMER_REPO && customerRepositories.size() > 0) {
                                    echo "生成 repository_list.info 文件..."
                                    def repoListContent = generateRepositoryListInfo(customerRepositories)
                                    def repoListLocalPath = "${env.WORKSPACE}/temp_repository_list_${channel}.info"
                                    writeFile file: repoListLocalPath, text: repoListContent
                                    
                                    def repoListRemoteUrl = "${svnChannelUrl}/repository_list.info"
                                    uploadFileToSvn(repoListLocalPath, repoListRemoteUrl, "repository_list.info")
                                    
                                    // 清理临时文件
                                    sh "rm -f '${repoListLocalPath}'"
                                }
                            } else {
                                failCount++
                            }
                            
                            // 上传 mapping 文件（如存在）
                            def mappingFiles = sh(script: "find out/ -type f -name 'mapping_*${channel}*' 2>/dev/null || true", returnStdout: true).trim()
                            if (mappingFiles) {
                                mappingFiles.split('\n').each { mappingPath ->
                                    mappingPath = mappingPath.trim()
                                    if (mappingPath) {
                                        def mappingFileName = mappingPath.tokenize('/').last()
                                        def mappingRemoteUrl = "${svnChannelUrl}/${mappingFileName}"
                                        uploadFileToSvn(mappingPath, mappingRemoteUrl, "mapping")
                                    }
                                }
                            }
                        }
                        
                        // 存储上传的 APK 信息供后续阶段使用
                        env.UPLOADED_APKS_JSON = groovy.json.JsonOutput.toJson(uploadedApks)
                        
                        echo "=== 上传结果统计 ==="
                        echo "成功上传: ${uploadSuccessCount} 个 APK"
                        echo "跳过已存在: ${skipCount} 个文件"
                        echo "上传失败: ${failCount} 个文件"
                        
                        if (failCount == 0) {
                            env.UPLOAD_SUCCESS = 'true'
                            if (uploadSuccessCount > 0) {
                                env.UPLOAD_RESULT_MESSAGE = "成功上传 ${uploadSuccessCount} 个 APK 到新目录结构"
                            } else {
                                env.UPLOAD_RESULT_MESSAGE = "所有文件在 SVN 中已存在，未上传新文件"
                            }
                        } else {
                            env.UPLOAD_SUCCESS = 'false'
                            env.UPLOAD_RESULT_MESSAGE = "文件上传过程中出现 ${failCount} 个错误"
                            error env.UPLOAD_RESULT_MESSAGE
                        }
                    }
                }
            }
        }
        
        // [已禁用] 推送到 Customer Git 仓库的功能已注释，apk_urls.txt 仅上传到 SVN
        // Requirements 6.1: 生成或更新对应的 apk_urls.txt 文件
        // 从 apkinfo.json 的 repositoryList 中读取关联的 Customer 仓库信息，或使用构建参数指定
        // stage('Update APK URLs') {
        //     when {
        //         expression {
        //             // Requirements 6.1: WHEN APK 上传到 SVN 完成后且 UPDATE_CUSTOMER_REPO 为 true
        //             // THEN THE Pipeline SHALL 从 apkinfo.json 的 repositoryList 中读取关联的 Customer 仓库信息
        //             env.SHOULD_COMPILE == 'true' && 
        //             env.isGerritTriggerCause != 'true' && 
        //             params.UPLOAD_TO_SVN && 
        //             params.UPDATE_CUSTOMER_REPO
        //         }
        //     }
        //     steps {
        //         script {
        //             // 检查是否有构建参数指定 Customer 仓库（三个参数都有值才生效）
