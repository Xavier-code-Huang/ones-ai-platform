/**
 * 解析 CUSTOMER_REPOSITORIES 配置字符串
 * 
 * @param configString 配置字符串，格式：server1|repo1:branch1,server2|repo2:branch2
 * @return CustomerRepository 列表，每个元素包含 server、repository 和 branch 字段
 * 
 * Requirements: 4.1, 4.4, 9.1, 9.4
 * 
 * 支持两种格式：
 * 1. 单行格式（逗号分隔）：server1|repo1:branch1,server2|repo2:branch2
 * 2. 多行格式（换行符分隔）：
 *    server1|repo1:branch1
 *    server2|repo2:branch2
 */
def parseCustomerRepositories(String configString) {
    def repositories = []
    
    if (!configString || configString.trim().isEmpty()) {
        return repositories
    }
    
    // 支持多行格式和单行格式
    // 如果包含换行符，按换行符分隔；否则按逗号分隔
    def entries
    if (configString.contains('\n')) {
        // 多行格式：按换行符分隔
        entries = configString.split('\n')
    } else {
        // 单行格式：按逗号分隔
        entries = configString.split(',')
    }
    
    entries.each { entry ->
        entry = entry.trim()
        
        // 跳过空行和注释行
        if (!entry || entry.startsWith('#')) {
            return // continue to next entry
        }
        
        if (entry.contains('|') && entry.contains(':')) {
            // 格式：server|repo:branch
            def pipeIndex = entry.indexOf('|')
            def server = entry.substring(0, pipeIndex).trim()
            def repoAndBranch = entry.substring(pipeIndex + 1).trim()
            
            def colonIndex = repoAndBranch.lastIndexOf(':')
            if (colonIndex > 0) {
                def repo = repoAndBranch.substring(0, colonIndex).trim()
                def branch = repoAndBranch.substring(colonIndex + 1).trim()
                if (server && repo && branch) {
                    repositories.add([
                        server: server,
                        repository: repo,
                        branch: branch
                    ])
                }
            }
        } else if (entry.contains(':')) {
            // 兼容旧格式：repo:branch（无服务器地址）
            def colonIndex = entry.lastIndexOf(':')
            if (colonIndex > 0) {
                def repo = entry.substring(0, colonIndex).trim()
                def branch = entry.substring(colonIndex + 1).trim()
                if (repo && branch) {
                    repositories.add([
                        server: '',
                        repository: repo,
                        branch: branch
                    ])
                }
            }
        }
    }
    
    return repositories
}

/**
 * 生成 repository_list.info 文件内容
 * 
 * @param repositories CustomerRepository 列表，每个元素包含 server、repository 和 branch 字段
 * @return 格式化的 repository_list.info 内容字符串
 * 
 * Requirements: 4.2
 */
def generateRepositoryListInfo(List repositories) {
    if (!repositories || repositories.isEmpty()) {
        return '[]'
    }
    
    def content = '['
    repositories.each { repo ->
        if (repo.server) {
            content += "server:${repo.server},repository:${repo.repository},branch:${repo.branch};"
        } else {
            // 兼容无服务器地址的情况
            content += "repository:${repo.repository},branch:${repo.branch};"
        }
    }
    content += ']'
    
    return content
}

