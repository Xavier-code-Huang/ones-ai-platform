// ========== 新增的编译标志检查方法 ==========

// 检查编译标志
def checkCompileFlag() {
    def buildConfig = [:]
    try {
        if (env.BUILD_CONFIG_JSON) {
            def lazyMap = new groovy.json.JsonSlurper().parseText(env.BUILD_CONFIG_JSON)
            buildConfig = convertToSerializableMap(lazyMap)
        }
    } catch (Exception e) {
        echo "解析构建配置失败: ${e.getMessage()}"
        buildConfig = getDefaultBuildConfig()
    }
    
    // 获取编译标志，默认为true以保持向后兼容
    def compileFlag = getConfigValue(buildConfig, 'COMPILE_TEST', 'true').toBoolean()
    env.SHOULD_COMPILE = compileFlag.toString()
    
    // 获取强制覆盖上传标志，默认为false
    def forceUpload = getConfigValue(buildConfig, 'FORCE_UPLOAD', 'true').toBoolean()
    env.FORCE_UPLOAD = forceUpload.toString()
    
    // 获取责任人列表
    def responsiblePersons = getConfigValue(buildConfig, 'RESPONSIBLE_PERSONS', '')
    env.RESPONSIBLE_PERSONS = responsiblePersons
    
    // 获取触发控制配置
    def gerritTriggerEnabled = getConfigValue(buildConfig, 'GERRIT_TRIGGER_ENABLED', 'true').toBoolean()
    def timerTriggerEnabled = getConfigValue(buildConfig, 'TIMER_TRIGGER_ENABLED', 'true').toBoolean()
    
    echo "编译配置检查:"
    echo "- 是否编译: ${env.SHOULD_COMPILE}"
    echo "- 强制覆盖上传: ${env.FORCE_UPLOAD}"
    echo "- 责任人: ${env.RESPONSIBLE_PERSONS}"
    echo "- Gerrit触发启用: ${gerritTriggerEnabled}"
    echo "- 定时触发启用: ${timerTriggerEnabled}"
    
    // 检查触发控制逻辑
    // Requirements 1.1, 1.2, 1.3: Gerrit 触发控制
    if (env.isGerritTriggerCause == 'true' && !gerritTriggerEnabled) {
        echo "Gerrit触发已禁用 (GERRIT_TRIGGER_ENABLED=false)，跳过编译"
        env.SHOULD_COMPILE = 'false'
        env.SKIP_REASON = 'Gerrit触发已禁用'
        currentBuild.result = 'SUCCESS'
        echo "依据配置：Gerrit触发已禁用，不进行编译。构建流程正常结束。"
        return
    }
    
    // Requirements 2.1, 2.2: 定时触发控制
    if (env.isTimerTriggerCause == 'true' && !timerTriggerEnabled) {
        echo "定时触发已禁用 (TIMER_TRIGGER_ENABLED=false)，跳过编译"
        env.SHOULD_COMPILE = 'false'
        env.SKIP_REASON = '定时触发已禁用'
        currentBuild.result = 'SUCCESS'
        echo "依据配置：定时触发已禁用，不进行编译。构建流程正常结束。"
        return
    }
    
    if (!compileFlag) {
        echo "编译标志设置为false，跳过后续编译阶段"
        currentBuild.result = 'SUCCESS'
        echo "依据参数设置：编译为false，不进行编译。构建流程正常结束。"
    }
}

/**
 * 检查是否应该跳过编译基于触发类型和配置
 * 
 * @param isGerritTrigger 是否为 Gerrit 触发
 * @param isTimerTrigger 是否为定时触发
 * @param gerritTriggerEnabled Gerrit 触发是否启用
 * @param timerTriggerEnabled 定时触发是否启用
 * @return Map 包含 shouldSkip (boolean) 和 reason (String)
 */
def checkTriggerControl(boolean isGerritTrigger, boolean isTimerTrigger, 
                        boolean gerritTriggerEnabled, boolean timerTriggerEnabled) {
    // Requirements 1.1, 1.2: Gerrit 触发控制
    if (isGerritTrigger && !gerritTriggerEnabled) {
        return [shouldSkip: true, reason: 'Gerrit触发已禁用']
    }
    
    // Requirements 2.1, 2.2: 定时触发控制
    if (isTimerTrigger && !timerTriggerEnabled) {
        return [shouldSkip: true, reason: '定时触发已禁用']
    }
    
    return [shouldSkip: false, reason: '']
}

