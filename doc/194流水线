    }
    
    // 验证Gradle可执行文件
    if (!fileExists(env.GRADLE_SCRIPT)) {
        error "Gradle可执行文件不存在: ${env.GRADLE_SCRIPT}"
    }
    
    // 验证Java是否存在
    if (!fileExists(env.COMPILE_JAVA_HOME)) {
        error "Java版本不存在: ${env.COMPILE_JAVA_HOME}. 请检查配置的JAVA_VERSION或联系管理员安装对应版本"
    }
    
    // 验证Java版本
    try {
        def javaVersionOutput = sh(script: "${env.COMPILE_JAVA_HOME}/bin/java -version 2>&1", returnStdout: true)
        echo "Java版本信息: ${javaVersionOutput}"
    } catch (Exception e) {
        error "Java版本验证失败: ${e.getMessage()}"
    }
    
    // 验证Gradle版本
    try {
        def gradleVersionOutput = sh(script: "${env.GRADLE_SCRIPT} --version", returnStdout: true)
