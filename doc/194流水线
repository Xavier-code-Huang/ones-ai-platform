    def isTimerTriggerCause = !currentBuild.getBuildCauses('hudson.triggers.TimerTrigger$TimerTriggerCause').isEmpty()
    def isGerritTriggerCause = !currentBuild.getBuildCauses('com.sonyericsson.hudson.plugins.gerrit.trigger.hudsontrigger.GerritCause').isEmpty()
    isGerritTriggerCause |= !currentBuild.getBuildCauses('com.sonyericsson.hudson.plugins.gerrit.trigger.hudsontrigger.GerritUserCause').isEmpty()
    
    env.isUserIdCause = isUserIdCause.toString()
    env.isTimerTriggerCause = isTimerTriggerCause.toString()
    env.isGerritTriggerCause = isGerritTriggerCause.toString()
    
    // 获取Gerrit提交人信息
    if (env.isGerritTriggerCause == 'true') {
        env.GERRIT_SUBMITTER_EMAIL = getGerritSubmitterEmail()
        env.GERRIT_SUBMITTER_NAME = getGerritSubmitterName()
        echo "Gerrit提交人: ${env.GERRIT_SUBMITTER_NAME} <${env.GERRIT_SUBMITTER_EMAIL}>"
    }
    
    // 设置实际分支
    if (env.isGerritTriggerCause == 'true') {
        env.ACTUAL_BRANCH = getGerritBranchFromRefspec()
    } else {
        def manualBranch = params.MANUAL_BRANCH_SELECT
        if (!manualBranch || manualBranch.trim().isEmpty() || manualBranch == 'N/A') {
            error "未指定分支，请在手动触发时选择分支"
        }
        env.ACTUAL_BRANCH = manualBranch.trim()
    }
}

def setupProjectInfo() {
    if (env.isGerritTriggerCause == 'true') {
        env.PROJECT_NAME = getGerritProjectName()
    } else {
        env.PROJECT_NAME = params.MANUAL_PROJECT
    }
    
    env.ACTUAL_CODE_REPO = "${env.CODE_REPO_BASE}/${env.PROJECT_NAME}"
}

def getGerritProjectName() {
    if (env.GERRIT_PROJECT) {
        return env.GERRIT_PROJECT
    }
    echo "警告：无法确定Gerrit项目，使用默认项目 XbhAdverPlayer3.0"
    return 'XbhAdverPlayer3.0'
}

def getGerritBranchFromRefspec() {
    if (env.GERRIT_BRANCH) {
        return env.GERRIT_BRANCH
    }
    if (env.GERRIT_REFSPEC) {
        def refspec = env.GERRIT_REFSPEC
        if (refspec.startsWith('refs/heads/')) {
            return refspec.replace('refs/heads/', '')
        }
    }
    try {
        def branch = sh(script: 'git branch --show-current', returnStdout: true).trim()
        if (branch) {
            return branch
        }
    } catch (Exception e) {
        echo "无法从git获取分支信息: ${e.getMessage()}"
    }
    error "无法获取Gerrit分支信息，请检查触发参数或Gerrit事件"
}

// 获取Gerrit提交人邮箱
def getGerritSubmitterEmail() {
    // 优先从commit message中提取Author邮箱
    def authorEmail = extractAuthorEmailFromCommitMessage()
    if (authorEmail) {
        echo "从commit message中提取到Author邮箱: ${authorEmail}"
        return authorEmail
    }
    
    // 其次使用GERRIT_PATCHSET_UPLOADER_EMAIL（最近上传者）
    if (env.GERRIT_PATCHSET_UPLOADER_EMAIL) {
        return env.GERRIT_PATCHSET_UPLOADER_EMAIL
    }
    // 使用GERRIT_CHANGE_OWNER_EMAIL（变更所有者）
    if (env.GERRIT_CHANGE_OWNER_EMAIL) {
        return env.GERRIT_CHANGE_OWNER_EMAIL
    }
    // 兜底：尝试从其他Gerrit环境变量获取
    if (env.GERRIT_EVENT_ACCOUNT_EMAIL) {
        return env.GERRIT_EVENT_ACCOUNT_EMAIL
    }
    echo "警告：无法获取Gerrit提交人邮箱"
    return ''
}

// 从commit message中提取Author邮箱
def extractAuthorEmailFromCommitMessage() {
    try {
        // 尝试从GERRIT_CHANGE_COMMIT_MESSAGE环境变量获取
        def commitMessage = env.GERRIT_CHANGE_COMMIT_MESSAGE ?: ''
        
        // 如果环境变量不存在，尝试通过git命令获取
        if (!commitMessage || commitMessage.allWhitespace) {
            commitMessage = sh(script: 'git log -1 --pretty=%B', returnStdout: true).trim()
        }
        
        if (commitMessage && !commitMessage.allWhitespace) {
            // 使用正则表达式匹配 Author : name <email@domain.com> 格式
            def matcher = commitMessage =~ /Author\s*:\s*[^<]*<([^>]+)>/
            if (matcher.find()) {
                def email = matcher.group(1).trim()
                echo "成功从commit message中提取Author邮箱: ${email}"
                return email
            } else {
                echo "commit message中未找到Author邮箱格式"
            }
        }
    } catch (Exception e) {
        echo "从commit message提取Author邮箱失败: ${e.getMessage()}"
    }
    
    return ''
}

// 获取Gerrit提交人姓名
def getGerritSubmitterName() {
    // 优先从commit message中提取Author姓名
    def authorName = extractAuthorNameFromCommitMessage()
    if (authorName) {
        return authorName
    }
    
    // 其次使用GERRIT_PATCHSET_UPLOADER_NAME（最近上传者）
    if (env.GERRIT_PATCHSET_UPLOADER_NAME) {
        return env.GERRIT_PATCHSET_UPLOADER_NAME
    }
    // 使用GERRIT_CHANGE_OWNER_NAME（变更所有者）
    if (env.GERRIT_CHANGE_OWNER_NAME) {
        return env.GERRIT_CHANGE_OWNER_NAME
    }
    // 兜底：尝试从其他Gerrit环境变量获取
    if (env.GERRIT_EVENT_ACCOUNT_NAME) {
        return env.GERRIT_EVENT_ACCOUNT_NAME
    }
    echo "警告：无法获取Gerrit提交人姓名"
    return '未知提交人'
}

// 从commit message中提取Author姓名
def extractAuthorNameFromCommitMessage() {
    try {
        // 尝试从GERRIT_CHANGE_COMMIT_MESSAGE环境变量获取
        def commitMessage = env.GERRIT_CHANGE_COMMIT_MESSAGE ?: ''
        
        // 如果环境变量不存在，尝试通过git命令获取
        if (!commitMessage || commitMessage.allWhitespace) {
            commitMessage = sh(script: 'git log -1 --pretty=%B', returnStdout: true).trim()
        }
        
        if (commitMessage && !commitMessage.allWhitespace) {
            // 使用正则表达式匹配 Author : name <email@domain.com> 格式
            def matcher = commitMessage =~ /Author\s*:\s*([^<]+?)\s*<[^>]+>/
            if (matcher.find()) {
                def name = matcher.group(1).trim()
                if (name && !name.allWhitespace) {
                    echo "成功从commit message中提取Author姓名: ${name}"
                    return name
                }
            }
        }
    } catch (Exception e) {
        echo "从commit message提取Author姓名失败: ${e.getMessage()}"
    }
    
    return ''
}

// ========== 优化的通知功能 ==========

// 发送通知的通用方法
def sendNotification(buildStatus, buildInfo) {
    def notificationConfig = getNotificationConfig()
    
    // 检查是否启用通知
    if (!params.ENABLE_NOTIFICATION) {
        echo "通知功能已禁用，跳过通知发送"
        return
    }
    
    // 检查通知级别是否匹配
    if (!shouldSendNotification(buildStatus, notificationConfig)) {
        echo "通知级别不匹配，跳过通知发送 (当前级别: ${notificationConfig.notificationLevel}, 构建状态: ${buildStatus})"
        return
    }
    
    // 发送邮件通知
    if (notificationConfig.emailEnabled) {
        sendEmailNotification(buildStatus, buildInfo, notificationConfig)
    }
    
    // 发送企业微信通知
    if (notificationConfig.wechatEnabled) {
        sendWechatNotification(buildStatus, buildInfo, notificationConfig)
    }
    
    echo "通知发送完成"
}

// 获取通知配置
def getNotificationConfig() {
    // 从环境变量或配置文件读取配置
    def config = [
        emailEnabled: true,
        wechatEnabled: true,
        emailRecipients: params.DEFAULT_EMAIL_RECIPIENTS,  // 默认接收者，总是包含
        notificationLevel: 'ALL', // ALL, SUCCESS_ONLY, FAILURE_ONLY
        includeBuildDetails: true,
        includeFileList: true,
        includeErrorLogs: true
    ]
    
    // 添加配置文件中的责任人到邮件接收者
    if (env.RESPONSIBLE_PERSONS && !env.RESPONSIBLE_PERSONS.allWhitespace) {
        config.emailRecipients = config.emailRecipients + ',' + env.RESPONSIBLE_PERSONS
        echo "添加责任人到邮件接收者: ${env.RESPONSIBLE_PERSONS}"
    }
    
    // 添加Gerrit提交人到邮件接收者（仅Gerrit触发时）
    if (env.isGerritTriggerCause == 'true' && env.GERRIT_SUBMITTER_EMAIL && !env.GERRIT_SUBMITTER_EMAIL.allWhitespace) {
        config.emailRecipients = config.emailRecipients + ',' + env.GERRIT_SUBMITTER_EMAIL
        echo "添加Gerrit提交人到邮件接收者: ${env.GERRIT_SUBMITTER_NAME} <${env.GERRIT_SUBMITTER_EMAIL}>"
    }
    
    // 添加手动输入的邮箱到邮件接收者（仅手动触发时）
    if (env.isGerritTriggerCause != 'true' && params.MANUAL_EMAIL && !params.MANUAL_EMAIL.allWhitespace) {
        config.emailRecipients = config.emailRecipients + ',' + params.MANUAL_EMAIL
        echo "添加手动输入的邮箱到接收者: ${params.MANUAL_EMAIL}"
    }
    
    return config
}

// 检查通知级别是否匹配
def shouldSendNotification(buildStatus, notificationConfig) {
    switch(notificationConfig.notificationLevel) {
        case 'ALL':
            return true
        case 'SUCCESS_ONLY':
            return buildStatus == 'SUCCESS'
        case 'FAILURE_ONLY':
            return buildStatus == 'FAILURE'
        default:
            return true
    }
}

// 构建通知信息
def buildNotificationInfo(buildStatus) {
    def downloadUrl = "${env.SVN_BASE_URL}/${env.PROJECT_NAME}/${env.ACTUAL_BRANCH}"
    
    // 安全获取配置信息
    def buildConfig = [:]
    def javaVersion = env.DEFAULT_JAVA_VERSION
    def gradleVersion = env.DEFAULT_GRADLE_VERSION
    
    try {
        if (env.BUILD_CONFIG_JSON) {
            def lazyMap = new groovy.json.JsonSlurper().parseText(env.BUILD_CONFIG_JSON)
            buildConfig = convertToSerializableMap(lazyMap)
            javaVersion = getConfigValue(buildConfig, 'JAVA_VERSION', env.DEFAULT_JAVA_VERSION)
            gradleVersion = getConfigValue(buildConfig, 'GRADLE_VERSION', env.DEFAULT_GRADLE_VERSION)
        }
    } catch (Exception e) {
        echo "解析构建配置失败: ${e.getMessage()}"
    }
    
    def triggerType = env.isGerritTriggerCause == 'true' ? 'Gerrit自动触发' : '手动触发'
    def platform = env.isGerritTriggerCause == 'true' ? 'all' : params.PARAM_PLATFORM
    
    // 根据上传状态生成详细的上传说明
    def uploadStatus = env.UPLOAD_RESULT_MESSAGE ?: '未上传'
    def uploadExplanation = ''
    
    if (uploadStatus.contains('成功上传')) {
        uploadExplanation = 'SVN中未检测到同名文件，已成功上传新文件'
    } else if (uploadStatus.contains('已存在')) {
        uploadExplanation = 'SVN中已存在同名文件，构建过程正常但未进行上传'
    } else if (uploadStatus.contains('错误')) {
        uploadExplanation = '文件上传过程中出现错误'
    } else {
        uploadExplanation = '未进行文件上传'
    }
    
    // 获取 apk_urls.txt 更新状态
    def apkUrlsUpdateStatus = env.APK_URLS_UPDATE_STATUS ?: '未执行'
    
    // 获取 Customer 仓库更新状态
    def customerRepoUpdateStatus = '未执行'
    if (params.UPDATE_CUSTOMER_REPO) {
        if (env.APK_URLS_UPDATE_STATUS) {
            customerRepoUpdateStatus = '已更新'
        } else if (env.SHOULD_COMPILE == 'true' && env.isGerritTriggerCause != 'true' && params.UPLOAD_TO_SVN) {
            customerRepoUpdateStatus = '待更新'
        }
    } else {
        customerRepoUpdateStatus = '已禁用'
    }
    
    // 获取关联的 Customer 仓库数量（从 apkinfo.json 的 repositoryList 统计）
    // 数量信息现在存储在 CUSTOMER_REPO_COUNT 环境变量中
    def customerRepoCount = 0
    try {
        if (env.CUSTOMER_REPO_COUNT) {
            customerRepoCount = env.CUSTOMER_REPO_COUNT.toInteger()
        }
    } catch (Exception e) {
        echo "获取 Customer 仓库数量失败: ${e.getMessage()}"
    }
    
    return [
        projectName: env.PROJECT_NAME,
        branch: env.ACTUAL_BRANCH,
        buildNumber: env.BUILD_NUMBER,
        buildStatus: buildStatus,
        buildUrl: env.BUILD_URL,
        triggerType: triggerType,
        platform: platform,
        buildType: params.IS_NOT_DEBUG,
        uploadStatus: uploadStatus,
        uploadExplanation: uploadExplanation,
        javaVersion: javaVersion,
        gradleVersion: gradleVersion,
        downloadUrl: downloadUrl,
        apkFiles: env.APK_FILES ?: '',
        mappingFiles: env.MAPPING_FILES ?: '',
        responsiblePersons: env.RESPONSIBLE_PERSONS ?: '',
        gerritSubmitterName: env.GERRIT_SUBMITTER_NAME ?: '',
        gerritSubmitterEmail: env.GERRIT_SUBMITTER_EMAIL ?: '',
        isAutoTrigger: false,
        uploadSkipped: false,
        // 新增：apk_urls.txt 更新状态 (Requirements 7.1)
        apkUrlsUpdateStatus: apkUrlsUpdateStatus,
        // 新增：Customer 仓库更新状态
        customerRepoUpdateStatus: customerRepoUpdateStatus,
        // 新增：关联的 Customer 仓库数量
        customerRepoCount: customerRepoCount
    ]
}

// 发送邮件通知
def sendEmailNotification(buildStatus, buildInfo, notificationConfig) {
    def subject = "${buildInfo.projectName}自动构建 - Build #${buildInfo.buildNumber} - ${buildStatus}"
    
    def emailBody = """
${buildInfo.projectName}自动构建状态报告
========================================

构建信息:
- 项目名称: ${buildInfo.projectName}
- 构建分支: ${buildInfo.branch}
- 构建编号: #${buildInfo.buildNumber}
- 构建状态: ${buildStatus}
- 触发方式: ${buildInfo.triggerType}
"""
    
    if (notificationConfig.includeBuildDetails) {
        emailBody += """
- 构建平台: ${buildInfo.platform}
- 构建类型: ${buildInfo.buildType}

上传状态:
- 上传结果: ${buildInfo.uploadStatus}
- 说明: ${buildInfo.uploadExplanation}
- SVN 路径: ReleaseApk/xbh3/${buildInfo.projectName}/${buildInfo.branch}/

Customer 仓库更新:
- 更新状态: ${buildInfo.customerRepoUpdateStatus}
- 关联仓库数量: ${buildInfo.customerRepoCount}
- apk_urls.txt 更新: ${buildInfo.apkUrlsUpdateStatus}

技术信息:
- 构建工具: Gradle ${buildInfo.gradleVersion}, Java ${buildInfo.javaVersion}
- 构建链接: ${buildInfo.buildUrl}
  ⚠️ 重要说明：此链接请在安全空间中查看！
"""
    }
    
    // 添加责任人信息
    if (buildInfo.responsiblePersons && !buildInfo.responsiblePersons.allWhitespace) {
        emailBody += """
- 项目责任人: ${buildInfo.responsiblePersons}
"""
    }
    
    // 添加Gerrit提交人信息（仅Gerrit触发时）
    if (buildInfo.gerritSubmitterEmail && !buildInfo.gerritSubmitterEmail.allWhitespace) {
        if (buildInfo.gerritSubmitterName && !buildInfo.gerritSubmitterName.allWhitespace && buildInfo.gerritSubmitterName != '未知提交人') {
            emailBody += """
- Gerrit提交人: ${buildInfo.gerritSubmitterName} <${buildInfo.gerritSubmitterEmail}>
"""
        } else {
            emailBody += """
- Gerrit提交人: ${buildInfo.gerritSubmitterEmail}
"""
        }
    }
    
    emailBody += "\n"
    
    if (buildStatus == 'SUCCESS' && notificationConfig.includeFileList) {
        if (buildInfo.isAutoTrigger) {
            // 自动触发：只显示编译成功，不提供下载链接
            emailBody += "编译验证:\n"
            emailBody += "- ✅ 所有flavor编译成功\n"
            emailBody += "- ℹ️ 自动触发构建仅验证编译，未上传文件\n\n"
        } else if (buildInfo.apkFiles && !buildInfo.apkFiles.allWhitespace) {
            // 手动触发：提供下载链接
            emailBody += "生成文件:\n"
            emailBody += "\nAPK文件:\n"
            def apkList = buildInfo.apkFiles.split('\n')
            apkList.each { fileName ->
                emailBody += "- ${buildInfo.downloadUrl}/${fileName}\n"
            }
            
            if (buildInfo.mappingFiles && !buildInfo.mappingFiles.allWhitespace) {
                emailBody += "\nMapping文件:\n"
                def mappingList = buildInfo.mappingFiles.split('\n')
                mappingList.each { fileName ->
                    emailBody += "- ${buildInfo.downloadUrl}/${fileName}\n"
                }
            }
            emailBody += "\n"
        }
    } else if (buildStatus == 'FAILURE' && notificationConfig.includeErrorLogs) {
        emailBody += "错误信息:\n"
        emailBody += "- 详细日志: ${buildInfo.buildUrl}console\n"
        
        // 添加错误日志摘要
        if (buildInfo.errorLog && buildInfo.errorLog != '无法获取详细错误日志') {
            emailBody += "- 错误摘要:\n"
            def errorLines = buildInfo.errorLog.split('\n')
            def errorCount = Math.min(errorLines.size(), 10) // 最多显示10行错误
            for (int i = 0; i < errorCount; i++) {
                emailBody += "  ${errorLines[i]}\n"
            }
            if (errorLines.size() > 10) {
                emailBody += "  ... (更多错误信息请查看完整日志)\n"
            }
        }
        emailBody += "\n"
    }
    
    emailBody += "========================================\n"
    emailBody += "构建时间: ${new Date()}\n"
    
    // 打印调试信息
    echo "准备发送邮件..."
    echo "收件人: ${notificationConfig.emailRecipients}"
    echo "主题: ${subject}"
    
    // 发送邮件（无重试）
    try {
        emailext(
            subject: subject,
            to: notificationConfig.emailRecipients,
            body: emailBody
        )
        echo "邮件通知发送成功"
    } catch (Exception e) {
        echo "邮件发送失败: ${e.getMessage()}"
        // 不重试，直接记录失败
    }
}

