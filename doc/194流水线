pipeline {
    agent { label '94-node1' }
    options {
        disableConcurrentBuilds()
    }
    parameters {
        choice(
            name: 'MANUAL_PROJECT',
            choices: ['Keyguard_Edu2.0','XbhAccount', 'Launcher5.0', 'SystemSetting_Edu2.0','XbhSystemUI','XBHFM','XbhCloudDisk','NavigationEdu2.0','XbhLiveTv','XbhAiServer','XbhAi','XbhAdverPlayer3.0','XbhFactoryMenu','XbhWidgets','XbhUniversalPlayer','XbhAiScreen','Quickpass','XbhFloatMenu','XbhWelcome2.0','XbhSpotlight','XbhBrowser','Votekit','XbhCalendar','XbhTimer','HardwareDetect','Calculator','XbhGallery','XbhScreenRecorder','XbhEyeProtection','SetupWizard','OTA2.0','LOTAUI','XbhFinger','SystemSetting_Edu2.0_public','XBHWhiteBoard4.0','XbhDms','XbhSerialService'],
            description: '手动触发时选择项目（Gerrit触发自动识别）'
        )
        reactiveChoice(
            name: 'MANUAL_BRANCH_SELECT',
            choiceType: 'PT_SINGLE_SELECT',
            description: '手动触发时选择分支',
            referencedParameters: 'MANUAL_PROJECT',
            script: new org.biouno.unochoice.model.GroovyScript(
                new org.jenkinsci.plugins.scriptsecurity.sandbox.groovy.SecureGroovyScript('''
                    def project = MANUAL_PROJECT
                    def repoBase = 'http://git@192.168.1.194:8089/a'
                    def repoUrl = "${repoBase}/${project}"
                    try {
                        if (!project) {
                            return ["N/A"]
                        }
                        def command = ["git", "ls-remote", "-h", repoUrl]
                        def proc = command.execute()
                        proc.waitFor()
                        if (proc.exitValue() == 0) {
                            def branches = proc.in.text.readLines().collect {
                                it.split()[1].replaceAll('refs/heads/', '')
                            }.sort()
                            return branches
                        }
                        return ["N/A"]
                    } catch (Exception e) {
                        return ["N/A"]
                    }
                ''', true),
                new org.jenkinsci.plugins.scriptsecurity.sandbox.groovy.SecureGroovyScript("return ['N/A']", true)
            )
        )
        string(
            name: 'MANUAL_BRANCH',defaultValue:'',description: 'Gerrit自动触发传入的分支（手动触发不使用）'
        )
        string(
            name: 'PARAM_PLATFORM',defaultValue:'all',description: '手动触发时输入编译平台（Gerrit触发自动识别）'
        )
        choice(
            name: 'IS_NOT_DEBUG',
            choices: ['Release','Debug'],
            description: '是否为调试包'
        )
        string(
            name: 'MANUAL_EMAIL',
            defaultValue: '',
            description: '手动触发时的额外通知邮箱（可选，多个邮箱用逗号分隔）'
        )
        string(
            name: 'DEFAULT_EMAIL_RECIPIENTS',
            defaultValue: 'yixiang.huang@lango-tech.cn',
            description: '默认邮件接收者，无论编译上传是否成功或配置文件是否合适，都会发送通知'
        )
        string(
            name: 'PARAM_DEBUG_MODE',
            defaultValue: '',
            description: '调试模式：留空正常，timer强制定时触发，gerrit强制Gerrit触发'
        )
        booleanParam(
            name: 'ENABLE_NOTIFICATION',
            defaultValue: true,
            description: '是否启用邮件和企业微信通知'
        )
        booleanParam(
            name: 'UPLOAD_TO_SVN',
            defaultValue: true,
            description: '是否上传编译产物到 SVN'
        )
        booleanParam(
            name: 'UPDATE_CUSTOMER_REPO',
            defaultValue: true,
            description: '是否更新 Customer 仓库相关信息文件'
        )
        string(
            name: 'GIT_REPOSITORY_SERVER',
            defaultValue: '',
            description: '固件仓库服务器地址（可选）。例如: 192.168.1.182:8080。当三个 GIT_REPOSITORY_* 参数都有值时，将忽略 apkInfo.json 中的 repositoryList'
        )
        string(
            name: 'GIT_REPOSITORY_PATH',
            defaultValue: '',
            description: '固件仓库路径（可选）。例如: rk3576_U/platform/Customer'
        )
        string(
            name: 'GIT_REPOSITORY_BRANCH',
            defaultValue: '',
            description: '固件仓库分支（可选）。例如: develop-1.0.0-EDLA'
        )
    }
    environment {
        // 基础路径配置
        GRADLE_BASE_DIR = '/opt/gradle'
        JAVA_BASE_DIR = '/usr/lib/jvm'
        CODE_REPO_BASE = 'http://git@192.168.1.194:8089/a'
