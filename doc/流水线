                        ERROR_RETRY_COUNT=0
                    fi
                else
                    NO_LOG_COUNT=\$((NO_LOG_COUNT + 1))
                    echo >&2 "WARN: 无法获取测试日志或日志为空 (尝试 \${NO_LOG_COUNT}/3)..."
                    
                    if [ \$NO_LOG_COUNT -ge 3 ]; then
                        echo >&2 "ERROR: 连续 3 次无法获取有效日志，停止监控"
                        break
                    fi
                fi
                
                rm -f "\$TEMP_LOG"
                
                echo >&2 "等待\${CHECK_INTERVAL}秒后再次检查日志..."
                sleep \$CHECK_INTERVAL
            done

            echo >&2 "测试监控完成"
            
            END_TIME=\$(get_timestamp_ms)
            EXECUTE_DURATION=\$((END_TIME - START_TIME))

