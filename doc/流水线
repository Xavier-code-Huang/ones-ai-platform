                    current_retry=\$((current_retry + 1))
                    if [ \$current_retry -lt \$MAX_RETRIES ]; then
                        echo >&2 "等待 \$RETRY_DELAY 秒后重试..."
                        sleep \$RETRY_DELAY
                    fi
                    DEV_URL=""
                fi
