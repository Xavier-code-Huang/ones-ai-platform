            if [ ! -f "./test_package.zip" ]; then
                echo >&2 "ERROR: 测试包不存在"
                echo "TEST_PACKAGE_MISSING" > ${env.WORKSPACE}/test_failure_reason.txt
                exit 1
            fi

            # echo >&2 "等待3分钟后开始执行测试..."
            # sleep 180

            echo >&2 "开始执行测试..."
            echo >&2 "目标设备: \$DEV_URL"

            curl -s -X POST -b ~/cookies.txt "\${DEV_URL}run" \\
                -H "Content-Type: application/zip" \\
                --data-binary @test_package.zip || {
                echo >&2 "ERROR: 测试执行失败"
                exit 1
            }

            echo >&2 "测试已启动，开始监控测试日志..."

            # 步骤4.5: 监控测试执行日志
            echo >&2 "步骤4.5: 监控测试执行日志"
            MONITOR_START_TIME=\$(date +%s)
            MAX_MONITOR_TIME=3600  # 最大监控时间1小时
            CHECK_INTERVAL=30       # 每30秒检查一次
            LAST_LOG_SIZE=0
            NO_LOG_COUNT=0          # 连续获取不到日志的次数
            ERROR_RETRY_COUNT=0     # 检测到错误后的重试次数
            MAX_ERROR_RETRIES=2     # 检测到错误后最大重试次数

            while true; do
                CURRENT_TIME=\$(date +%s)
                ELAPSED_TIME=\$((CURRENT_TIME - MONITOR_START_TIME))
                
                if [ \$ELAPSED_TIME -gt \$MAX_MONITOR_TIME ]; then
                    echo >&2 "WARN: 测试监控超时 (超过\${MAX_MONITOR_TIME}秒)，继续收集结果"
                    break
                fi

                # 获取当前日志
                TEMP_LOG="/tmp/test_log_\${ELAPSED_TIME}.tmp"
                curl -s -b ~/cookies.txt -o "\$TEMP_LOG" "\${DEV_URL}run?type=log"
                
                if [ -f "\$TEMP_LOG" ] && [ -s "\$TEMP_LOG" ]; then
                    NO_LOG_COUNT=0
                    CURRENT_SIZE=\$(stat -c%s "\$TEMP_LOG" 2>/dev/null || echo 0)
                    
                    if [ "\$CURRENT_SIZE" -gt "\$LAST_LOG_SIZE" ]; then
                        echo >&2 "=== 测试日志更新 (\${ELAPSED_TIME}秒) ==="
                        # 显示新增的日志内容
                        if [ "\$LAST_LOG_SIZE" -gt 0 ]; then
                            tail -c +\$((LAST_LOG_SIZE + 1)) "\$TEMP_LOG" | head -50
                        else
                            head -50 "\$TEMP_LOG"
                        fi
                        echo >&2 "=== 日志更新结束 ==="
                        LAST_LOG_SIZE=\$CURRENT_SIZE
                    fi
                    
                    # 检查测试是否完成 (通过检查日志中是否包含完成标记)
                    if grep -q "测试完成\\|Test completed\\|All tests finished\\|FINISHED" "\$TEMP_LOG" 2>/dev/null; then
                        echo >&2 "检测到测试完成标记，停止监控"
                        break
                    fi
                    
                    # 检查是否有错误或失败标记
                    if grep -q "测试失败\\|Test failed\\|ERROR\\|FAILED" "\$TEMP_LOG" 2>/dev/null; then
                        ERROR_RETRY_COUNT=\$((ERROR_RETRY_COUNT + 1))
                        echo >&2 "WARN: 检测到测试错误 (尝试 \${ERROR_RETRY_COUNT}/\${MAX_ERROR_RETRIES})..."
                        
                        if [ \$ERROR_RETRY_COUNT -ge \$MAX_ERROR_RETRIES ]; then
                            echo >&2 "ERROR: 连续 \${MAX_ERROR_RETRIES} 次检测到测试错误，停止监控"
