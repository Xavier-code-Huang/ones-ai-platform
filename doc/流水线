            else
                echo "暂无详细测试报告" >> \${WORKSPACE}/test_summary_${summaryFileName}.txt
            fi
            
            # ✅ 添加测试执行状态信息（供MessageStep解析）
            # 注意：这里需要传入Groovy变量到shell，所以我们在外部设置
            echo "" >> \${WORKSPACE}/test_summary_${summaryFileName}.txt
            echo "测试执行状态:" >> \${WORKSPACE}/test_summary_${summaryFileName}.txt
            echo "-------------" >> \${WORKSPACE}/test_summary_${summaryFileName}.txt
            
            # 追加阶段时长
            {
                echo ""
                echo "阶段时长:"
                echo "--------"
                echo "环境设置:     \${SETUP_SEC} 秒"
                echo "设备锁定:     \${LOCK_SEC} 秒"
                echo "固件更新:     \${UPDATE_SEC} 秒"
                echo "测试执行:     \${EXECUTE_SEC} 秒"
                echo "结果收集:     \${COLLECT_SEC} 秒"
                echo "设备解锁:     \${UNLOCK_SEC} 秒"
                echo "----------------"
                echo "总计:         \${TOTAL_SEC} 秒"
            } >> \${WORKSPACE}/test_summary_${summaryFileName}.txt

            # 调试：检查文件是否生成
            if [ -f "\${WORKSPACE}/test_summary_${summaryFileName}.txt" ]; then
                echo >&2 "✅ 测试总结文件已生成: \${WORKSPACE}/test_summary_${summaryFileName}.txt"
                ls -la \${WORKSPACE}/test_summary_${summaryFileName}.txt >&2
            else
                echo >&2 "❌ 测试总结文件生成失败"
            fi
            
            END_TIME=\$(get_timestamp_ms)
            COLLECT_DURATION=\$((END_TIME - START_TIME))

            # 步骤6: 解锁设备
            echo >&2 "步骤6: 解锁设备"
            START_TIME=\$(get_timestamp_ms)
            
            echo >&2 "解锁设备: \$DEV_URL"
            curl -s -b ~/cookies.txt -X POST "\${DEV_URL}unlock" && echo >&2 "设备解锁成功" || echo >&2 "WARN: 设备解锁可能失败"

            # 清理临时文件
            rm -f /tmp/device_url.txt
            
            END_TIME=\$(get_timestamp_ms)
            UNLOCK_DURATION=\$((END_TIME - START_TIME))

            # 计算总耗时（毫秒和秒）
            TOTAL_MS=\$(( \${SETUP_DURATION} + \${LOCK_DURATION} + \${UPDATE_DURATION} + \${EXECUTE_DURATION} + \${COLLECT_DURATION} + \${UNLOCK_DURATION} ))
            TOTAL_SEC=\$(( \${TOTAL_MS} / 1000 ))
            
            # ✅ 输出时长结果到stdout（供TestStep读取），同时保存到文件
            echo "SETUP_DURATION=\${SETUP_DURATION}"
            echo "LOCK_DURATION=\${LOCK_DURATION}"
            echo "UPDATE_DURATION=\${UPDATE_DURATION}"
            echo "EXECUTE_DURATION=\${EXECUTE_DURATION}"
            echo "COLLECT_DURATION=\${COLLECT_DURATION}"
            echo "UNLOCK_DURATION=\${UNLOCK_DURATION}"
            echo "TOTAL_MS=\${TOTAL_MS}"
            echo "TOTAL_SEC=\${TOTAL_SEC}"
            
            # 同时保存到文件以备后续使用
            {
                echo "SETUP_DURATION=\${SETUP_DURATION}"
                echo "LOCK_DURATION=\${LOCK_DURATION}"
                echo "UPDATE_DURATION=\${UPDATE_DURATION}"
                echo "EXECUTE_DURATION=\${EXECUTE_DURATION}"
                echo "COLLECT_DURATION=\${COLLECT_DURATION}"
                echo "UNLOCK_DURATION=\${UNLOCK_DURATION}"
                echo "TOTAL_MS=\${TOTAL_MS}"
                echo "TOTAL_SEC=\${TOTAL_SEC}"
            } > \${WORKSPACE}/test_durations.txt
            
            echo >&2 "所有测试阶段完成，时长统计已输出"
            echo >&2 "总耗时: \${TOTAL_SEC} 秒 (\${TOTAL_MS} 毫秒)"
            """,
            returnStatus: true
        )

        // 根据exit code判断结果
        if (scriptStatus == 0) {
            testResult = 'SUCCESS'
        } else if (scriptStatus == 2) {
            testResult = 'RETRY'
            // ✅ 明确设置失败原因，防止发送无数据邮件
            env.TEST_FAILURE_REASON = 'DEVICE_BUSY'
        } else {
            testResult = 'FAILURE'
        }

        // 从文件读取时长信息
        def durationsFile = "${env.WORKSPACE}/test_durations.txt"
        if (fileExists(durationsFile)) {
            echo "=== 读取时长统计文件 ==="
            def durationsContent = readFile(file: durationsFile)
            echo "文件内容:\n${durationsContent}"
            
            def durationLines = durationsContent.split('\n')
            for (line in durationLines) {
                line = line.trim()
                if (line.startsWith('SETUP_DURATION=')) {
                    def value = line.split('=')[1].trim()
                    stageDurations['setup'] = (value.toLong() / 1000.0)
                    echo "解析 SETUP_DURATION: ${value} -> ${stageDurations['setup']}s"
                } else if (line.startsWith('LOCK_DURATION=')) {
                    def value = line.split('=')[1].trim()
                    stageDurations['lock'] = (value.toLong() / 1000.0)
                    echo "解析 LOCK_DURATION: ${value} -> ${stageDurations['lock']}s"
                } else if (line.startsWith('UPDATE_DURATION=')) {
                    def value = line.split('=')[1].trim()
                    stageDurations['update'] = (value.toLong() / 1000.0)
                    echo "解析 UPDATE_DURATION: ${value} -> ${stageDurations['update']}s"
                } else if (line.startsWith('EXECUTE_DURATION=')) {
                    def value = line.split('=')[1].trim()
                    stageDurations['execute'] = (value.toLong() / 1000.0)
                    echo "解析 EXECUTE_DURATION: ${value} -> ${stageDurations['execute']}s"
                } else if (line.startsWith('COLLECT_DURATION=')) {
                    def value = line.split('=')[1].trim()
                    stageDurations['collect'] = (value.toLong() / 1000.0)
                    echo "解析 COLLECT_DURATION: ${value} -> ${stageDurations['collect']}s"
                } else if (line.startsWith('UNLOCK_DURATION=')) {
                    def value = line.split('=')[1].trim()
                    stageDurations['unlock'] = (value.toLong() / 1000.0)
                    echo "解析 UNLOCK_DURATION: ${value} -> ${stageDurations['unlock']}s"
                }
            }
            echo "=== 时长统计解析完成 ==="
            echo "stageDurations: ${stageDurations}"
        } else {
            echo "⚠️ 警告: 时长统计文件不存在: ${durationsFile}"
        }

        echo "=== 单个测试任务成功完成 ==="

    } catch (Exception e) {
        echo "测试执行异常: ${e.getMessage()}"
        testResult = 'FAILURE'

        // 确保设备被解锁
        if (env.CURRENT_DEVICE_URL) {
            try {
                unlockDevice(env.CURRENT_DEVICE_URL)
            } catch (unlockException) {
                echo "解锁设备时发生异常: ${unlockException.getMessage()}"
            }
        }
    }

    // 处理测试结果
    if (testResult == 'SUCCESS') {
        // ✅ 使用Instance构建号的独立目录结构进行 stash
        def instanceBuildNumber = env.BUILD_NUMBER  // Instance 自己的构建号
        def buildResultPath = "output_result/${instanceBuildNumber}"
        
        echo "检查测试结果目录: ${buildResultPath}/reports"
        
        if (fileExists("${buildResultPath}/reports")) {
            // ✅ 修复：使用统一的stash命名规则（替换特殊字符）
            def safeProjectName = taskInfo.project_name?.replaceAll('[/_]', '-') ?: 'unknown'
            def safeBuildNumber = taskInfo.build_number?.toString()?.replaceAll('[/_]', '-') ?: 'unknown'
            def stashName = "allure-results-${safeProjectName}-${safeBuildNumber}"
            
            echo "✅ 准备 stash 测试结果: ${buildResultPath}"
            echo "   Instance 构建号: ${instanceBuildNumber}"
            echo "   Stash 名称: ${stashName}"
            stash name: stashName, includes: "${buildResultPath}/**"
            echo "✅ 已 stash 测试结果: ${buildResultPath}"
        } else {
            echo "⚠️ 警告: 测试报告目录不存在: ${buildResultPath}/reports"
            
            // 调试：列出 output_result 目录内容
            sh """
                echo "📁 调试: output_result 目录内容:"
                ls -la ${env.WORKSPACE}/output_result/ || echo "output_result 目录不存在"
            """
        }
    }

    return testResult
}

