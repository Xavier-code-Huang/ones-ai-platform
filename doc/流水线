/**
 * Autotest-TestStep-Instance Pipeline
 * 用途：执行单个自动化测试任务实例
 * 部署位置：test-agent 节点、
 * 参数：
 *   - TASK_FILE_NAME: 任务文件名
 *   - TASK_JSON: 任务JSON内容
 */

pipeline {
    agent {
        label 'test-agent'
    }

    parameters {
        string(name: 'TASK_FILE_NAME', defaultValue: '', description: '任务文件名')
        text(name: 'TASK_JSON', defaultValue: '', description: '任务JSON内容')
        string(name: 'DEVICE_LOCK_MAX_RETRIES', defaultValue: '3', description: '设备锁定最大重试次数')
    }

    options {
        timestamps()
        timeout(time: 300, unit: 'MINUTES')  // 单个测试超时时间
        buildDiscarder(logRotator(numToKeepStr: '50'))
    }

    environment {
        TEST_NODE_IP = '127.0.0.1'
        TEST_NODE_USER = 'jenkins'
    }

    stages {
        stage('解析任务参数') {
            steps {
                script {
                    echo "=== 解析任务参数 ==="
                    echo "任务文件: ${params.TASK_FILE_NAME}"

                    if (!params.TASK_JSON) {
                        error "TASK_JSON 参数为空"
                    }

                    try {
                        // 解析任务JSON
                        def taskInfo = parseJsonToMap(params.TASK_JSON)
                        
                        env.TASK_INFO_JSON = new groovy.json.JsonOutput().toJson(taskInfo)

                        // 调试：打印TASK_JSON和解析结果
                        echo "=== 调试信息 ==="
                        echo "原始TASK_JSON长度: ${params.TASK_JSON.length()}"
                        echo "解析后的taskInfo类型: ${taskInfo.getClass()}"
                        echo "project_name: ${taskInfo.project_name}"
                        echo "build_number: ${taskInfo.build_number}"
                        echo "firmware_path: ${taskInfo.firmware_path}"
                        echo "test_board_type: ${taskInfo.test_board_type}"
                        echo "customer_version: ${taskInfo.customer_version}"
                        echo "==============="

                        // 验证必要参数
                        def missingParams = []
                        if (!taskInfo.project_name) missingParams << "project_name"
                        if (!taskInfo.firmware_path) missingParams << "firmware_path"
                        if (!taskInfo.test_board_type) missingParams << "test_board_type"
                        
                        if (missingParams) {
                            error "任务信息不完整：缺少必要参数 ${missingParams.join(', ')}"
                        }

                        // ✅ 这里新增：从 firmware_path 提取固件版本号，并写回 taskInfo
                        def fwVersion = extractFirmwareVersion(taskInfo.firmware_path ?: '')
                        taskInfo.firmware_version = fwVersion

                        // ✅ 重新序列化：确保后续阶段 parse env.TASK_INFO_JSON 时能拿到 firmware_version
                        env.TASK_INFO_JSON = new groovy.json.JsonOutput().toJson(taskInfo)

                        echo "firmware_version: ${fwVersion}"

                        // ⚠️ 重要：不要覆盖 Jenkins 内置的 BUILD_NUMBER！
                        // 保存任务信息到环境变量（使用 TASK_BUILD_NUMBER 而不是 BUILD_NUMBER）
                        env.PROJECT_NAME = taskInfo.project_name ?: ""
                        env.TASK_BUILD_NUMBER = taskInfo.build_number ?: ""  // ✅ 任务的构建号
                        env.FIRMWARE_PATH = taskInfo.firmware_path ?: ""
                        env.TEST_BOARD_TYPE = taskInfo.test_board_type ?: ""
                        env.AGENT_NAME = taskInfo.agent_name ?: ""
                        env.UPLOAD_SERVER = taskInfo.upload_server ?: "ChangSha"
                        env.CUSTOMER_VERSION = taskInfo.customer_version ?: ""
                        env.RETRY_COUNT = taskInfo.retry_count ?: 0
                        
                        echo "=== 构建号说明 ==="
                        echo "Instance 构建号 (env.BUILD_NUMBER): ${env.BUILD_NUMBER}"
                        echo "任务构建号 (env.TASK_BUILD_NUMBER): ${env.TASK_BUILD_NUMBER}"
                        echo "================="
                        
                    } catch (Exception e) {
                        echo "JSON解析异常: ${e.getMessage()}"
                        echo "StackTrace: ${e.getStackTrace().join('\n')}"
                        error "解析任务JSON失败: ${e.getMessage()}"
                    }
                }
            }
        }

        stage('执行自动化测试') {
            steps {
                withCredentials([sshUserPrivateKey(
                    credentialsId: 'rainier-ssh-rsa',
                    keyFileVariable: 'GIT_SSH_KEY',
                    usernameVariable: 'GIT_USER'
                )]) {
                    script {
                        try {
                            echo "开始执行自动化测试..."
                            echo "TASK_INFO_JSON 类型: ${env.TASK_INFO_JSON.getClass()}"
                            
                            def taskInfo = parseJsonToMap(env.TASK_INFO_JSON)
                            
                            def testResult = performAutoTest(taskInfo)
                            env.TEST_RESULT = testResult

                            if (testResult == 'SUCCESS') {
                                echo "✅ 测试执行成功"
                                // ✅ 立即标记测试执行成功（用于在 post.unstable 中区分失败原因）
                                env.TEST_EXECUTION_SUCCESS = 'true'
                            } else {
                                echo "❌ 测试执行失败: ${testResult}"
                                currentBuild.result = 'FAILURE'
                            }
                            
                        } catch (Exception e) {
                            echo "测试执行阶段异常: ${e.getClass().getName()}: ${e.getMessage()}"
                            echo "StackTrace: ${e.getStackTrace().join('\n')}"
                            currentBuild.result = 'FAILURE'
                            env.TEST_RESULT = 'FAILURE'
                        }
                    }
                }
            }
        }

        stage('Generate Report') {
            agent { label '101-node1' }
            tools {
                allure 'Allure-2.33.0'
            }
            when {
                expression { env.TEST_RESULT == 'SUCCESS' }
            }
            steps {
                script {
                    def taskInfo = parseJsonToMap(env.TASK_INFO_JSON ?: '{}')
                    // ✅ 修复：使用与stash时相同的命名规则（替换特殊字符）
                    def safeProjectName = taskInfo.project_name?.replaceAll('[/_]', '-') ?: 'unknown'
                    def safeBuildNumber = taskInfo.build_number?.toString()?.replaceAll('[/_]', '-') ?: 'unknown'
                    def stashName = "allure-results-${safeProjectName}-${safeBuildNumber}"
                    
                    echo "正在 unstash 测试结果: ${stashName}"
                    unstash stashName
                    
                    // ✅ 按照Instance构建号创建独立的报告目录结构
                    // 路径：allure-reports/<instance_build_number>/<project_name>-<task_build_number>
                    def instanceBuildNumber = env.BUILD_NUMBER  // Instance 自己的构建号
                    def taskBuildNumber = taskInfo.build_number  // 任务的构建号
                    def buildNumberDir = "${env.WORKSPACE}/allure-reports/${instanceBuildNumber}"
                    def reportDir = "${buildNumberDir}/${taskInfo.project_name}-${taskBuildNumber}"
                    
                    echo "创建报告目录: ${reportDir}"
                    echo "  Instance 构建号: ${instanceBuildNumber}"
                    echo "  任务构建号: ${taskBuildNumber}"
                    sh "mkdir -p ${reportDir}"
                    
                    echo "生成 Allure 报告..."
                    // ✅ 从Instance构建号目录读取测试结果
                    allure([
                        includeProperties: false,
                        jdk: '',
                        reportBuildPolicy: "ALWAYS", 
                        results: [[path: "output_result/${instanceBuildNumber}/reports"]],
                        report: "${reportDir}",
                        properties: []
                    ])

                    // ✅ 打包 Allure 报告
                    def zipFileName = "allure-report-${taskInfo.project_name}-${taskBuildNumber}.zip"
                    echo "📦 打包 Allure 报告: ${zipFileName}"
                    sh """
                        cd ${buildNumberDir}
                        zip -r ${env.WORKSPACE}/${zipFileName} ${taskInfo.project_name}-${taskBuildNumber}
                    """
                    
                    def allureZipStashName = "allure-report-zip-${safeProjectName}-${safeBuildNumber}"
                    stash name: allureZipStashName, includes: zipFileName
                    env.ALLURE_ZIP_STASH_NAME = allureZipStashName
                    env.ALLURE_ZIP_FILE_NAME = zipFileName

                    // ✅ 将 Allure 报告压缩包复制到共享目录 (processing)，供 TestStep 流水线处理
                    def sharedProcessingDir = "/home/jenkins/autotest_scan/processing"
                    sh """
                        mkdir -p ${sharedProcessingDir}
                        cp ${env.WORKSPACE}/${zipFileName} ${sharedProcessingDir}/${zipFileName}
                        echo "✅ Allure 报告压缩包已复制到共享目录: ${sharedProcessingDir}/${zipFileName}"
                    """

                    // 拷贝报告给EDLA属性识别使用（以上游任务名-构建号的形式）
                    def reportCopyForEDLA = sh(
                        script: "cp -r ${env.WORKSPACE}/output_result/${instanceBuildNumber} ${env.WORKSPACE}/output_result/${env.PROJECT_NAME}-${env.TASK_BUILD_NUMBER}", 
                        returnStatus: true
                    )
                    
                    // ✅ 检查文件夹复制状态
                    if (reportCopyForEDLA == 0) {
                        echo "✅ 成功复制构建文件夹"
                        echo "   源文件夹: output_result/${instanceBuildNumber}"
                        echo "   目标文件夹: output_result/${env.PROJECT_NAME}-${env.TASK_BUILD_NUMBER}"
                        
                        // 验证目标文件夹是否存在
                        def copyVerify = sh(
                            script: "test -d ${env.WORKSPACE}/output_result/${env.PROJECT_NAME}-${env.TASK_BUILD_NUMBER} && echo '目标文件夹验证成功' || echo '目标文件夹验证失败'",
                            returnStdout: true
                        ).trim()
                        echo "   验证结果: ${copyVerify}"
                    } else {
                        echo "⚠️ 文件夹复制失败或出现异常，错误码: ${reportCopyForEDLA}"
                    }
                    
                    // ✅ 打印报告内容到日志（读取当前Instance构建的报告）
                    def reportPreview = sh(
                        script: "cat ${env.WORKSPACE}/output_result/${instanceBuildNumber}/output_result/allure_report_*.txt 2>/dev/null || echo '暂无测试报告内容'", 
                        returnStdout: true
                    ).trim()
                    
                    echo "=== Allure 测试报告 (Instance #${instanceBuildNumber}, 任务 #${taskBuildNumber}) ==="
                    echo reportPreview
                    echo "======================="
                    
                    // 保存报告预览到环境变量，供后续使用
                    env.ALLURE_REPORT_PREVIEW = reportPreview
                    
                    // ✅ 可选：清理超过7天的旧报告目录
                    try {
                        sh """
                            find ${env.WORKSPACE}/allure-reports -maxdepth 1 -type d -mtime +7 -exec rm -rf {} \\; 2>/dev/null || true
                            find /home/disk1/jenkins-workspace/workspace/Autotest-TestStep-Instance/output_result -maxdepth 1 -type d -mtime +7 -exec rm -rf {} \\; 2>/dev/null || true 
                            find /home/disk1/jenkins-workspace/workspace/Autotest-TestStep-Instance/allure-reports -maxdepth 1 -type d -mtime +7 -exec rm -rf {} \\; 2>/dev/null || true 
                        """
                        echo "已清理7天前的旧报告目录"
                    } catch (Exception e) {
                        echo "清理旧报告时出错: ${e.getMessage()}"
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                def taskInfo = parseJsonToMap(env.TASK_INFO_JSON ?: '{}')
                echo "测试实例执行成功（所有测试用例通过）: ${taskInfo.project_name}-${taskInfo.build_number}"
                
                // post.success 只在所有stage都成功且Allure没有将状态改为UNSTABLE时执行
                // 此时 env.TEST_EXECUTION_SUCCESS 应该已经在 "执行自动化测试" stage 中设置
                currentBuild.description = "✅ 测试执行成功，所有用例通过\n任务: ${params.TASK_FILE_NAME}"
                env.TEST_FAILURE_REASON = "NONE"
            }
        }
        unstable {
            script {
                def taskInfo = parseJsonToMap(env.TASK_INFO_JSON ?: '{}')
                
                echo "构建状态为 UNSTABLE，检查失败原因..."
                echo "TEST_EXECUTION_SUCCESS = ${env.TEST_EXECUTION_SUCCESS}"
                echo "TEST_FAILURE_REASON = ${env.TEST_FAILURE_REASON}"
                
                // UNSTABLE 可能由两种情况导致：
                // 1. 测试执行成功，但 Allure 报告显示有用例失败（env.TEST_EXECUTION_SUCCESS == 'true'）
                // 2. 测试执行失败，failure 块中设置为 UNSTABLE（env.TEST_FAILURE_REASON 已设置）
                
                if (env.TEST_EXECUTION_SUCCESS == 'true') {
                    // 情况1：测试执行成功，但有用例失败（Allure导致UNSTABLE）
                    echo "✅ 测试执行成功，但存在失败的测试用例（Allure报告导致UNSTABLE）"
                    currentBuild.description = "⚠️ 测试执行成功，部分用例失败\n任务: ${params.TASK_FILE_NAME}"
                    // 保持 UNSTABLE 状态，但标记为测试成功类型
                    env.TEST_FAILURE_REASON = "TEST_CASES_FAILED"
                } else if (env.TEST_FAILURE_REASON == 'DEVICE_BUSY') {
                    // 情况2：设备占用（已在 failure 块中设置）
                    echo "⚠️ 测试因设备占用失败，已标记为UNSTABLE"
                    currentBuild.description = "⚠️ 设备占用，等待重试\n任务: ${params.TASK_FILE_NAME}"
                } else {
                    // 情况3：未知原因导致UNSTABLE（不应该出现，记录警告）
                    echo "⚠️ 未知原因导致UNSTABLE状态"
                    echo "   TEST_EXECUTION_SUCCESS = ${env.TEST_EXECUTION_SUCCESS}"
                    echo "   TEST_FAILURE_REASON = ${env.TEST_FAILURE_REASON}"
                    
                    // 默认判定为测试用例失败（因为如果是设备占用应该在failure块处理）
                    if (!env.TEST_FAILURE_REASON) {
                        env.TEST_FAILURE_REASON = "UNKNOWN"
                    }
                    currentBuild.description = "⚠️ UNSTABLE (${env.TEST_FAILURE_REASON})\n任务: ${params.TASK_FILE_NAME}"
                }
            }
        }
        failure {
            script {
                echo "测试执行失败"
                
                // 读取失败原因
                def failureReason = "UNKNOWN"
                def failureReasonFile = "${env.WORKSPACE}/test_failure_reason.txt"
                
                try {
                    if (fileExists(failureReasonFile)) {
                        failureReason = readFile(failureReasonFile).trim()
                        echo "检测到失败原因: ${failureReason}"
                    } else {
                        echo "未找到失败原因文件，使用默认值: UNKNOWN"
                    }
                } catch (Exception e) {
                    echo "读取失败原因文件时出错: ${e.message}"
                }
                
                // 保存失败原因到环境变量
                env.TEST_FAILURE_REASON = failureReason
                
                // 根据失败原因设置不同的构建结果和描述
                if (failureReason == "DEVICE_BUSY") {
                    // 设备占用，标记为UNSTABLE（表示需要重试但不是严重错误）
                    currentBuild.result = 'UNSTABLE'
                    currentBuild.description = "⚠️ 设备占用，等待重试\n任务: ${params.TASK_FILE_NAME}"
                    echo "设备占用失败，构建标记为UNSTABLE，任务将移回scan目录"
                } else {
                    // 其他失败，标记为FAILURE
                    currentBuild.result = 'FAILURE'
                    def reasonText = getFailureReasonText(failureReason)
                    currentBuild.description = "❌ 测试失败: ${reasonText}\n任务: ${params.TASK_FILE_NAME}"
                    echo "测试失败（原因: ${reasonText}），构建标记为FAILURE，任务将移到failed目录"
                }
            }
        }
        always {
            script {
                echo "实例执行完成 - 结果: ${currentBuild.currentResult}"
                echo "任务文件: ${params.TASK_FILE_NAME}"
                echo "Post Actions WORKSPACE: ${env.WORKSPACE}"

                // 确保设备被解锁
                try {
                    def devUrl = sh(
                        script: "cat /tmp/device_url.txt 2>/dev/null || echo ''",
                        returnStdout: true
                    ).trim()

                    if (devUrl) {
                        echo "尝试解锁设备: ${devUrl}"
                        sh(
                            script: """
                            curl -s -b ~/cookies.txt -X POST "${devUrl}unlock" && echo "设备解锁成功" || echo "WARN: 设备解锁可能失败"
                            """,
                            returnStatus: true
                        )
                    } else {
                        echo "未找到设备URL，跳过解锁"
                    }
                } catch (Exception e) {
                    echo "解锁设备时发生异常: ${e.getMessage()}"
                }
                
                // ✅ 第一步：在 test-agent 节点 stash 测试总结文件
                script {
                    try {
                        def taskInfo = parseJsonToMap(env.TASK_INFO_JSON ?: '{}')
                        def summaryFile = "test_summary_${params.TASK_FILE_NAME.replace('.json', '')}.txt"
                        def summaryPath = "${env.WORKSPACE}/${summaryFile}"
                        
                        // ✅ 在stash之前，追加测试执行状态到test_summary文件
                        if (fileExists(summaryPath)) {
                            def testStatus = ""
                            def buildResult = currentBuild.currentResult
                            
                            if (buildResult == 'SUCCESS') {
                                testStatus = "✅ 测试执行成功"
                            } else if (buildResult == 'UNSTABLE') {
                                if (env.TEST_EXECUTION_SUCCESS == 'true') {
                                    testStatus = "⚠️ 部分用例失败"
                                } else {
                                    testStatus = "⚠️ 测试执行异常"
                                }
                            } else if (buildResult == 'FAILURE') {
                                testStatus = "❌ 测试失败"
                            } else {
                                testStatus = "未知状态: ${buildResult}"
                            }
                            
                            sh """
                                echo "${testStatus}" >> ${summaryPath}
                            """
                            echo "✅ 已添加测试执行状态: ${testStatus}"
                        }
                        
                        // ✅ 修复：将stash名称中的特殊字符替换为合法字符（斜杠、下划线等替换为连字符）
                        def safeProjectName = taskInfo.project_name?.replaceAll('[/_]', '-') ?: 'unknown'
                        def safeBuildNumber = taskInfo.build_number?.toString()?.replaceAll('[/_]', '-') ?: 'unknown'
                        def stashName = "test-summary-${safeProjectName}-${safeBuildNumber}"
                        
                        echo "📦 准备stash测试总结文件（test-agent节点）..."
                        echo "   项目名: ${taskInfo.project_name}"
                        echo "   构建号: ${taskInfo.build_number}"
                        echo "   文件名: ${summaryFile}"
                        echo "   Stash名: ${stashName}"
                        
                        if (fileExists(summaryPath)) {
                            echo "✅ Stash 测试总结文件: ${summaryFile} (stash: ${stashName})"
                            stash name: stashName, includes: summaryFile
                            
                            // 同时也存档，以便查看
                            archiveArtifacts artifacts: summaryFile, allowEmptyArchive: true, fingerprint: true
                            echo "✅ 测试总结文件已 stash，可供跨节点获取"
                            
                            // ⚠️ 保存信息到环境变量供后续节点使用
                            env.SUMMARY_FILE_NAME = summaryFile
                            env.STASH_NAME = stashName
                        } else {
                            echo "⚠️ 警告: 测试总结文件不存在: ${summaryPath}"
                        }
                    } catch (Exception e) {
                        echo "⚠️ Stash 测试总结文件时出错: ${e.getMessage()}"
                    }
                }
                
                // ✅ 第二步：切换到 101-node1 节点，unstash 并复制到共享目录
                script {
                    if (env.STASH_NAME && env.SUMMARY_FILE_NAME) {
                        try {
                            echo "🔄 切换到 101-node1 节点处理文件传递..."
                            node('101-node1') {
                                ws {
                                    // 在 101-node1 节点 unstash 文件
                                    echo "📥 在 101-node1 节点 unstash 测试总结文件: ${env.STASH_NAME}"
                                    unstash name: env.STASH_NAME

                                    // 复制到共享扫描目录
                                    def sharedTempDir = "/home/jenkins/autotest_scan/processing"
                                    sh """
                                        mkdir -p ${sharedTempDir}
                                        cp ${env.SUMMARY_FILE_NAME} ${sharedTempDir}/${env.SUMMARY_FILE_NAME}
                                        echo "✅ 测试总结文件已在 101-node1 节点复制到共享目录: ${sharedTempDir}/${env.SUMMARY_FILE_NAME}"
                                        ls -lh ${sharedTempDir}/${env.SUMMARY_FILE_NAME}
                                    """

                                    // ✅ 第三步：额外备份到持久存储服务器 (10.10.10.181)
                                    // 注意：此步骤已移动到 Auto-test-teststep 流水线中统一处理
                                    // Instance 只负责将 zip 包复制到 processing 目录（已在 Generate Report 阶段完成）
                                    echo "ℹ️ Allure 报告备份将由 Auto-test-teststep 流水线处理"
                                }
                            }
                            echo "✅ 文件已成功传递到 101-node1 节点的共享目录"
                        } catch (Exception e) {
                            echo "⚠️ 在 101-node1 节点处理文件时出错: ${e.getMessage()}"
                            echo "   StackTrace: ${e.getStackTrace().join('\n')}"
                        }
                    } else {
                        echo "⚠️ 未找到stash信息，跳过文件传递"
                    }
                }
                
                // ✅ 输出最终的失败原因供 TestStep 读取（支持日志解析）
                try {
                    // 优先使用环境变量中的失败原因（由 post.success/unstable/failure 设置）
                    def finalReason = env.TEST_FAILURE_REASON
                    
                    // 如果环境变量没有设置，尝试从文件读取
                    if (!finalReason || finalReason == 'null') {
                        def failureReasonFile = "${env.WORKSPACE}/test_failure_reason.txt"
                        if (fileExists(failureReasonFile)) {
                            finalReason = readFile(failureReasonFile).trim()
                        }
                    }
                    
                    // 输出失败原因（使用 TestStep 能识别的格式）
                    if (finalReason && finalReason != 'null') {
                        echo "=== 测试失败原因: ${finalReason} ==="
                    } else {
                        // 如果没有失败原因，说明可能是测试完全成功
                        echo "=== 测试失败原因: NONE ==="
                    }
                } catch (Exception e) {
                    echo "输出失败原因时出错: ${e.message}"
                    echo "=== 测试失败原因: UNKNOWN ==="
                }
                
                // ✅ 第三步：返回 test-agent 节点发送即时专属通知
                script {
                    try {
                        def taskInfo = parseJsonToMap(env.TASK_INFO_JSON ?: '{}')
                        // 默认邮箱
                        def defaultEmail = 'yixiang.huang@lango-tech.cn'
                        if (!taskInfo.recipient_list || !taskInfo.recipient_list.trim()) {
                            taskInfo.recipient_list = defaultEmail
                            echo "ℹ️ 未设置专属通知邮箱，已自动添加默认邮箱: ${defaultEmail}"
                        } else if (!taskInfo.recipient_list.contains(defaultEmail)) {
                            // 如果已有收件人但不包含默认邮箱，则追加
                            taskInfo.recipient_list += ",${defaultEmail}"
                            echo "📧 已自动追加默认邮箱到专属通知列表: ${taskInfo.recipient_list}"
                        } else {
                            echo "📧 检测到专属通知邮箱列表，准备发送即时通知（test-agent节点）..."
                        }
                        sendImmediateNotification(taskInfo)
                    } catch (Exception e) {
                        echo "⚠️ 发送即时通知时出错: ${e.getMessage()}"
                        echo "   StackTrace: ${e.getStackTrace().join('\n')}"
                    }
                }
            }
        }
    }
}

