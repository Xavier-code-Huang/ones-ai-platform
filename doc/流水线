def extractFirmwareVersion(String firmwarePath) {
    if (!firmwarePath) return ''

    // 取文件名
    def fileName = firmwarePath.tokenize('/').last()
    if (!fileName) return ''

    // 去掉常见后缀
    fileName = fileName
        .replaceAll(/\.tar\.gz$/,'')
        .replaceAll(/\.tgz$/,'')
        .replaceAll(/\.zip$/,'')
        .replaceAll(/\.img$/,'')

    def parts = (fileName.split('_') as List)
    if (!parts || parts.size() < 2) return ''

    // 找到 14 位时间戳 token（如 20260105052412）
    int tsIndex = -1
    for (int i = 0; i < parts.size(); i++) {
        if ((parts[i] ?: '') ==~ /^\d{14}$/) {
            tsIndex = i
            break
        }
    }

    if (tsIndex < 0) {
        // 找不到时间戳：回退取末尾 4 段，避免太长
        return (parts.size() >= 4) ? parts[-4..-1].join('_') : fileName
    }

    // ✅ 只要「时间戳及其后面」：时间戳前面的全部不要
    return parts[tsIndex..-1].join('_')
}


