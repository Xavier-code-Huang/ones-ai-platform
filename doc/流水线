def getFailureReasonText(reason) {
    def reasonMap = [
        'DEVICE_BUSY': '设备占用',
        'FIRMWARE_UPDATE_FAILED': '固件更新失败',
        'TEST_PACKAGE_MISSING': '测试包不存在',
        'GIT_CLONE_FAILED': 'Git克隆失败',
        'TEST_PACKAGE_BUILD_FAILED': '测试包生成失败',
        'TEST_LOG_FETCH_FAILED': '测试日志获取失败',
        'TEST_RESULT_FETCH_FAILED': '测试结果获取失败',
        'UNKNOWN': '未知错误'
    ]
    
    return reasonMap[reason] ?: reason
}

def parseJsonToMap(String jsonString) {
    if (!jsonString) return [:]
    def parsed = new groovy.json.JsonSlurper().parseText(jsonString)
    if (parsed instanceof groovy.json.internal.LazyMap) {
        return new HashMap(parsed)
    }
    return parsed
}

// ==================== 即时专属通知功能 ====================

def sendImmediateNotification(taskInfo) {
    echo "开始发送即时专属通知: ${taskInfo.project_name}-${taskInfo.build_number}"

    // 🚫 设备占用时，不发送邮件（无论是否最后一次重试）
    if (env.TEST_FAILURE_REASON == "DEVICE_BUSY") {
        echo "🚫 检测到失败原因为 DEVICE_BUSY，跳过发送即时专属通知"
        return
    }

    // 收集当前Instance的测试结果信息
    def instanceInfo = collectCurrentInstanceInfo(taskInfo)

    // 判断测试状态
    def buildResult = currentBuild.currentResult
    def taskStatus = ""
    def statusIcon = ""
    def statusClass = ""

    if (buildResult == 'SUCCESS') {
        taskStatus = "成功"
        statusIcon = "✅"
        statusClass = "success"
    } else if (buildResult == 'UNSTABLE') {
        if (env.TEST_EXECUTION_SUCCESS == 'true' || env.TEST_FAILURE_REASON == 'TEST_CASES_FAILED') {
            taskStatus = "部分用例失败"
            statusIcon = "⚠️"
            statusClass = "warning"
        } else {
            taskStatus = "失败"
            statusIcon = "❌"
            statusClass = "failure"
        }
    } else {
        taskStatus = "失败"
        statusIcon = "❌"
        statusClass = "failure"
    }

    // ⚠️ 当通过率为 0% 时，强制视为测试失败（避免误判为“部分用例失败”）
    try {
        if (instanceInfo.passRate && instanceInfo.passRate != 'N/A') {
            def passRateValue = instanceInfo.passRate.replaceAll('%', '').toFloat()
            if (passRateValue == 0.0 && statusClass != 'failure') {
                echo "检测到通过率为 0%，将邮件状态强制标记为失败"
                taskStatus = "失败"
                statusIcon = "❌"
                statusClass = "failure"
            }
        }
    } catch (Exception e) {
        echo "解析通过率时出错，保持原有状态: ${e.getMessage()}"
    }

    // 生成邮件内容
    def emailSubject = "${statusIcon} 自动测试${taskStatus}通知 - ${taskInfo.project_real_name ?: taskInfo.project_name} #${taskInfo.build_number}"
    def emailBody = generateImmediateNotificationEmail(taskInfo, instanceInfo, taskStatus, statusIcon, statusClass)

    try {
        emailext(
            to: taskInfo.recipient_list,
            subject: emailSubject,
            mimeType: 'text/html',
            body: emailBody
        )
        echo "✅ 已发送即时专属通知到: ${taskInfo.recipient_list}"
    } catch (Exception e) {
        echo "❌ 发送即时专属通知失败: ${e.getMessage()}"
        echo "   StackTrace: ${e.getStackTrace().join('\n')}"
    }
}


def collectCurrentInstanceInfo(taskInfo) {
    // 收集当前Instance的测试结果信息（增强版：包含完整Allure报告数据）
    def instanceInfo = [
        buildNumber: env.BUILD_NUMBER ?: 'N/A',
        buildUrl: env.BUILD_URL ?: '#',
        testResult: currentBuild.currentResult,
        // 基础统计
        passRate: 'N/A',
        passedTests: 0,
        totalTests: 0,
        // 详细统计（Allure完整数据）
        totalCases: 0,           // 总用例数量（包括跳过的）
        failedTests: 0,          // 失败数量
        skippedTests: 0,         // 跳过数量
        brokenTests: 0,          // 中断数量
        unknownTests: 0,         // 未知数量
        failureRate: 'N/A',      // 失败率
        brokenRate: 'N/A',       // 中断率
        avgExecutionTime: 'N/A', // 平均执行时间
        // 其他信息
        duration: 'N/A',
        stageDurations: [:],
        testDevice: taskInfo.agent_name ?: '未指定',
        failureReason: env.TEST_FAILURE_REASON ?: 'NONE'
    ]
    
    try {
        // 先unstash测试总结文件到当前WORKSPACE
        def taskInfoUnstash = parseJsonToMap(env.TASK_INFO_JSON ?: '{}')
        def safeProjectName = taskInfoUnstash.project_name?.replaceAll('[/_]', '-') ?: 'unknown'
        def safeBuildNumber = taskInfoUnstash.build_number?.toString()?.replaceAll('[/_]', '-') ?: 'unknown'
        def stashName = "test-summary-${safeProjectName}-${safeBuildNumber}"
        echo "Unstash 测试总结文件: ${stashName}"
        unstash name: stashName
        
        // 尝试从测试总结文件读取详细测试结果
        def summaryFile = "test_summary_${params.TASK_FILE_NAME.replace('.json', '')}.txt"
        def summaryPath = "${env.WORKSPACE}/${summaryFile}"
        
        if (fileExists(summaryPath)) {
            def summaryContent = readFile(summaryPath)
            echo "读取测试总结文件内容"
            
            // ✅ 解析总用例数量（包括跳过的）
            def totalCasesPattern = /总用例数量\s+(\d+)/
            def totalCasesMatcher = summaryContent =~ totalCasesPattern
            if (totalCasesMatcher.find()) {
                instanceInfo.totalCases = totalCasesMatcher[0][1].toInteger()
                echo "提取到总用例数量: ${instanceInfo.totalCases}"
            }
            
            // ✅ 解析通过数量
            def passedPattern = /通过数量\s+(\d+)/
            def passedMatcher = summaryContent =~ passedPattern
            if (passedMatcher.find()) {
                instanceInfo.passedTests = passedMatcher[0][1].toInteger()
                echo "提取到通过数量: ${instanceInfo.passedTests}"
            }
            
            // ✅ 解析失败数量
            def failedPattern = /失败数量\s+(\d+)/
            def failedMatcher = summaryContent =~ failedPattern
            if (failedMatcher.find()) {
                instanceInfo.failedTests = failedMatcher[0][1].toInteger()
                echo "提取到失败数量: ${instanceInfo.failedTests}"
            }
            
            // ✅ 解析跳过数量
            def skippedPattern = /跳过数量\s+(\d+)/
            def skippedMatcher = summaryContent =~ skippedPattern
            if (skippedMatcher.find()) {
                instanceInfo.skippedTests = skippedMatcher[0][1].toInteger()
                echo "提取到跳过数量: ${instanceInfo.skippedTests}"
            }
            
            // ✅ 解析中断数量
            def brokenPattern = /中断数量\s+(\d+)/
            def brokenMatcher = summaryContent =~ brokenPattern
            if (brokenMatcher.find()) {
                instanceInfo.brokenTests = brokenMatcher[0][1].toInteger()
                echo "提取到中断数量: ${instanceInfo.brokenTests}"
            }
            
            // ✅ 解析未知数量
            def unknownPattern = /未知数量\s+(\d+)/
            def unknownMatcher = summaryContent =~ unknownPattern
            if (unknownMatcher.find()) {
                instanceInfo.unknownTests = unknownMatcher[0][1].toInteger()
                echo "提取到未知数量: ${instanceInfo.unknownTests}"
            }
            
            // ✅ 解析平均执行时间
            def avgTimePattern = /平均执行时间\s+([\d.]+)s/
            def avgTimeMatcher = summaryContent =~ avgTimePattern
            if (avgTimeMatcher.find()) {
                instanceInfo.avgExecutionTime = "${avgTimeMatcher[0][1]}s"
                echo "提取到平均执行时间: ${instanceInfo.avgExecutionTime}"
            }
            
            // ✅ 解析通过率（格式：通过率: XX% (XX/XX)）
            def passRatePattern = /通过率:\s*([\d.]+)%\s*\((\d+)\/(\d+)\)/
            def passRateMatcher = summaryContent =~ passRatePattern
            if (passRateMatcher.find()) {
                instanceInfo.passRate = "${passRateMatcher[0][1]}%"
                // totalTests 是有效测试数（不含跳过）
                instanceInfo.totalTests = passRateMatcher[0][3].toInteger()
                echo "提取到通过率: ${instanceInfo.passRate}, 有效测试数: ${instanceInfo.totalTests}"
            }
            
            // ✅ 解析失败率
            def failureRatePattern = /失败率:\s*([\d.]+)%/
            def failureRateMatcher = summaryContent =~ failureRatePattern
            if (failureRateMatcher.find()) {
                instanceInfo.failureRate = "${failureRateMatcher[0][1]}%"
                echo "提取到失败率: ${instanceInfo.failureRate}"
            }
            
            // ✅ 解析中断率
            def brokenRatePattern = /中断率:\s*([\d.]+)%/
            def brokenRateMatcher = summaryContent =~ brokenRatePattern
            if (brokenRateMatcher.find()) {
                instanceInfo.brokenRate = "${brokenRateMatcher[0][1]}%"
                echo "提取到中断率: ${instanceInfo.brokenRate}"
            }
            
            // 解析阶段时长（格式：阶段名: XX.XX 秒）
            def stageDurationPattern = /(\S+):\s*([\d.]+)\s*秒/
            summaryContent.findAll(stageDurationPattern).each { match ->
                def parts = match.split(':')
                if (parts.size() == 2) {
                    def stageName = parts[0].trim()
                                        
                    // 排除总计项，避免重复计算
                    if (stageName.contains("总用时") || stageName.contains("总计")) {
                        return
                    }
                    def duration = parts[1].replaceAll(/[^\d.]/, '').trim()
                    if (duration) {
                        instanceInfo.stageDurations[stageName] = duration
                    }
                }
            }
            
            echo "提取到 ${instanceInfo.stageDurations.size()} 个阶段时长"
        } else {
            echo "测试总结文件不存在: ${summaryPath}"
        }
        
        // 从时长文件读取阶段时长（作为备选方案）
        def durationsFile = "${env.WORKSPACE}/test_durations.txt"
        if (fileExists(durationsFile) && instanceInfo.stageDurations.size() == 0) {
            echo "=== 从时长文件读取阶段时长 ==="
            def durationsContent = readFile(durationsFile)
            echo "时长文件内容:\n${durationsContent}"
            
            def stageMapping = [
                'SETUP_DURATION': '环境设置',
                'LOCK_DURATION': '设备锁定',
                'UPDATE_DURATION': '固件更新',
                'EXECUTE_DURATION': '测试执行',
                'COLLECT_DURATION': '结果收集',
                'UNLOCK_DURATION': '设备解锁'
            ]
            
            durationsContent.split('\n').each { line ->
                line = line.trim()
                if (line.contains('=')) {
                    def parts = line.split('=', 2)
                    if (parts.size() == 2) {
                        def key = parts[0].trim()
                        def value = parts[1].trim()
                        
                        // 跳过 TOTAL_MS 和 TOTAL_SEC
                        if (key in ['TOTAL_MS', 'TOTAL_SEC']) {
                            return
                        }
                        
                        // 转换为中文名称和秒
                        if (stageMapping.containsKey(key)) {
                            try {
                                def seconds = (value.toLong() / 1000.0)
                                instanceInfo.stageDurations[stageMapping[key]] = String.format("%.2f", seconds)
                                echo "解析 ${key} -> ${stageMapping[key]}: ${value}ms = ${seconds}s"
                            } catch (Exception e) {
                                echo "解析时长失败: ${key} = ${value}, 错误: ${e.getMessage()}"
                            }
                        }
                    }
                }
            }
            echo "从时长文件提取到 ${instanceInfo.stageDurations.size()} 个阶段时长"
            echo "stageDurations: ${instanceInfo.stageDurations}"
        }
        
        // 计算总时长
        def totalDuration = 0.0
        instanceInfo.stageDurations.each { stage, duration ->
            try {
                totalDuration += duration.toFloat()
            } catch (Exception e) {
                // 忽略转换错误
            }
        }
        if (totalDuration > 0) {
            instanceInfo.duration = String.format("%.2f", totalDuration / 60.0) + " 分钟"
        }
        
        // ✅ 根据测试通过率判定实际测试结果（软件测试报告结论）
        // 通过率 >= 95%: 通过，通过率 < 95%: 失败
        def actualTestResult = "失败"  // 默认失败
        def actualTestResultStyle = "color: #f44336; font-weight: bold;"  // 红色
        if (instanceInfo.passRate != 'N/A') {
            try {
                def passRateValue = instanceInfo.passRate.replaceAll('%', '').toFloat()
                if (passRateValue >= 95.0) {
                    actualTestResult = "通过"
                    actualTestResultStyle = "color: #4CAF50; font-weight: bold;"  // 绿色
                } else {
                    actualTestResult = "失败"
                    actualTestResultStyle = "color: #f44336; font-weight: bold;"  // 红色
                }
                echo "=== 测试结果判定 ==="
                echo "通过率: ${instanceInfo.passRate}"
                echo "判定结果: ${actualTestResult} (阈值: 95%)"
                echo "==================="
            } catch (Exception e) {
                echo "解析通过率失败，使用默认结果: 失败"
                echo "错误: ${e.getMessage()}"
            }
        } else {
            echo "通过率不可用 (N/A)，使用默认结果: 失败"
        }
        instanceInfo.actualTestResult = actualTestResult
        instanceInfo.actualTestResultStyle = actualTestResultStyle
        
    } catch (Exception e) {
        echo "收集Instance信息时出错: ${e.getMessage()}"
    }
    
    return instanceInfo
}

