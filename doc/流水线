            # ✅ 清理旧的输出目录，为每个Instance构建创建独立的结果目录
            rm -rf \${WORKSPACE}/output_result/
            rm -rf \${WORKSPACE}/allure-report/
            rm -rf \${WORKSPACE}/output_report/
            
            # 创建以Instance构建号命名的独立目录
            # ⚠️ 重要：使用 Jenkins 的 BUILD_NUMBER（Instance自己的构建号）
            INSTANCE_BUILD_NUMBER="${env.BUILD_NUMBER}"
            BUILD_RESULT_DIR="\${WORKSPACE}/output_result/\${INSTANCE_BUILD_NUMBER}"
            mkdir -p "\${BUILD_RESULT_DIR}"
            mkdir -p \${WORKSPACE}/allure-report/
            chmod -R 755 \${WORKSPACE}/output_result

            echo >&2 "解压测试结果到Instance构建号目录: \${BUILD_RESULT_DIR} (Instance #\${INSTANCE_BUILD_NUMBER})"
            unzip -o \${WORKSPACE}/test_result.zip -d "\${BUILD_RESULT_DIR}" || {
                echo >&2 "WARN: 解压测试结果文件失败"
            }

            echo >&2 "保存测试总结报告..."
            
            # 调试信息
            echo >&2 "WORKSPACE: \${WORKSPACE}"
            echo >&2 "taskFileName: ${taskFileName}"
            echo >&2 "文件名: test_summary_${summaryFileName}.txt"
            
            # 将毫秒转换为秒（使用浮点除法）
            SETUP_SEC=\$(awk "BEGIN {printf \\"%.3f\\", \$SETUP_DURATION/1000}")
            LOCK_SEC=\$(awk "BEGIN {printf \\"%.3f\\", \$LOCK_DURATION/1000}")
            UPDATE_SEC=\$(awk "BEGIN {printf \\"%.3f\\", \$UPDATE_DURATION/1000}")
            EXECUTE_SEC=\$(awk "BEGIN {printf \\"%.3f\\", \$EXECUTE_DURATION/1000}")
            COLLECT_SEC=\$(awk "BEGIN {printf \\"%.3f\\", \$COLLECT_DURATION/1000}")
            UNLOCK_SEC=\$(awk "BEGIN {printf \\"%.3f\\", \$UNLOCK_DURATION/1000}")
            
            # 计算总时长（秒）
            TOTAL_SEC=\$(awk "BEGIN {printf \\"%.3f\\", (\$SETUP_DURATION + \$LOCK_DURATION + \$UPDATE_DURATION + \$EXECUTE_DURATION + \$COLLECT_DURATION + \$UNLOCK_DURATION) / 1000}")
            
            # 生成报告头
            {
                echo "测试报告"
                echo "========"
                echo "设备: \$DEV_URL"
                echo "时间: \$(date '+%Y-%m-%d %H:%M:%S')"
                echo "项目: ${projectName}"
                echo "构建: ${buildNumber}"
                echo "版本: ${customerVersion}"
                echo ""
                echo "测试结果:"
                echo "--------"
            } > \${WORKSPACE}/test_summary_${summaryFileName}.txt
            
