def findAndLockDevice(taskInfo) {
    echo "开始查找和锁定设备..."

    def result = sh(
        script: """
        #!/bin/bash
        set -e

        BASE_URL="https://rainier.lango-tech.com/v1"
        REASON="\$(basename \$0)@\$(cat /etc/hostname)"
        MAX_RETRIES=\${params.DEVICE_LOCK_MAX_RETRIES}
        LOCK_DURATION=10800
        RETRY_DELAY=5

        echo "设备查找参数:"
        echo "  项目: \${taskInfo.project_name}"
        echo "  构建: \${taskInfo.build_number}"
        echo "  板型: \${taskInfo.test_board_type}"
        echo "  设备名: \${taskInfo.agent_name ?: '未指定'}"

        current_retry=0
        locked=0
        DEV_URL=""

        while [ \$current_retry -lt \$MAX_RETRIES ]; do
            echo "=== 设备锁定尝试 \$((current_retry+1))/\$MAX_RETRIES ==="

            if [ -z "\${taskInfo.agent_name}" ] || [ "\${taskInfo.agent_name}" = "null" ]; then
                echo "使用BOARD参数查找设备: \${taskInfo.test_board_type}"
                DEV_URL=\$(curl -s -b ~/cookies.txt "\${BASE_URL}/list?BOARD=\${taskInfo.test_board_type}&LOCK_REASON=\$REASON|" | jq -r '.[] | .URL' | head -n1)
            else
                echo "使用NAME参数查找设备: \${taskInfo.agent_name}"
                DEV_URL=\$(curl -s -b ~/cookies.txt "\${BASE_URL}/list?NAME=\${taskInfo.agent_name}&LOCK_REASON=\$REASON|" | jq -r '.[] | .URL' | head -n1)
            fi

            if [ -z "\$DEV_URL" ]; then
                echo "WARN: 没有找到可用设备，尝试 \$((current_retry+1))/\$MAX_RETRIES"
                current_retry=\$((current_retry + 1))
                if [ \$current_retry -lt \$MAX_RETRIES ]; then
                    echo "等待 \$RETRY_DELAY 秒后重试..."
                    sleep \$RETRY_DELAY
                fi
                continue
            fi

            echo "尝试锁定设备: \$DEV_URL"
            LOCK_INFO=\$(curl -s -b ~/cookies.txt -X POST "\${DEV_URL}lock" \\
                -H "Content-Type: application/json" \\
                -d '{"reason": "'\$REASON'", "duration": '\$LOCK_DURATION'}')

            if [ -n "\$(echo "\$LOCK_INFO" | grep "Locked")" ]; then
                locked=1
                echo "SUCCESS: 成功锁定设备 \$DEV_URL"
                echo "\$DEV_URL" > /tmp/device_url.txt
                break
            else
                echo "WARN: 锁定设备 \$DEV_URL 失败: \$LOCK_INFO"
                current_retry=\$((current_retry + 1))
                if [ \$current_retry -lt \$MAX_RETRIES ]; then
                    echo "等待 \$RETRY_DELAY 秒后重试..."
                    sleep \$RETRY_DELAY
                fi
                DEV_URL=""
            fi
        done

        if [ \$locked -ne 1 ]; then
            echo "ERROR: 多次尝试后仍无法锁定设备"
            exit 2
        fi

        echo "设备锁定成功: \$DEV_URL"
        """,
        returnStatus: true
    )

    if (result == 2) {
        echo "设备锁定失败，需要重试"
        return null
    } else if (result != 0) {
        error "查找和锁定设备失败"
    }

    // 读取设备URL
    def devUrl = sh(
        script: "cat /tmp/device_url.txt 2>/dev/null || echo ''",
        returnStdout: true
    ).trim()

    if (!devUrl) {
        error "无法获取设备URL"
    }

    echo "设备锁定成功: ${devUrl}"
    return devUrl
}

