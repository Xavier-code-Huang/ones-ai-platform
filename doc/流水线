def performAutoTest(taskInfo) {
    echo "开始执行自动化测试: ${taskInfo.project_name}-${taskInfo.build_number}"
    
    // 添加类型检查和转换
    def localTaskInfo = parseJsonToMap(env.TASK_INFO_JSON)
    
    // 确保所有必要字段都存在
    if (!localTaskInfo.project_name || !localTaskInfo.firmware_path || !localTaskInfo.test_board_type) {
        error "任务信息不完整：project_name、firmware_path 或 test_board_type 缺失"
    }
    
    // 设置测试所需的环境变量
    env.SOURCE_PROJECT = localTaskInfo.project_name ?: ""
    env.PROJECT_REAL_NAME = localTaskInfo.project_real_name ?: (localTaskInfo.project_name ? localTaskInfo.project_name.split('/')[0] : "")
    env.FIRMWARE_PATH = localTaskInfo.firmware_path ?: ""
    env.PARAM_B_BOARD_TYPE = localTaskInfo.board_type ?: ""
    env.PARAM_T_BOARD_TYPE = localTaskInfo.test_board_type ?: ""
    env.PARAM_AGENT_NAME = localTaskInfo.agent_name ?: ""
    env.UPSTREAM_NODE_LOCATION = localTaskInfo.upload_server ?: "ChangSha"
    env.CUSTOMER_VERSION = localTaskInfo.customer_version ?: ""
    env.PARAM_START_AUTOTEST = true

    try {
        def testResult = runAutoTestScript(localTaskInfo)
        return testResult
    } catch (Exception e) {
        echo "测试执行异常: ${e.getClass().getName()}: ${e.getMessage()}"
        echo "StackTrace: ${e.getStackTrace().join('\n')}"
        return 'FAILURE'
    }
}

